        {
            "id": "calculating_average",
            "elements": [
                {
                    "type": "heading",
                    "content": "Calculating Average",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can combine `sum()` and `len()` to calculate the average of a list."
                },
                {
                    "type": "code",
                    "content": "scores = [80, 90, 85, 95]\ntotal = sum(scores)\ncount = len(scores)\naverage = total / count\nprint(f\"Average score: {average}\")",
                    "properties": {
                        "language": "python",
                        "output": "Average score: 87.5"
                    }
                },
                {
                    "type": "text",
                    "content": "The average is calculated by dividing the sum by the number of items."
                }
            ]
        },
