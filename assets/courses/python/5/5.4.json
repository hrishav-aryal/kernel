        {
            "id": "sum_function",
            "elements": [
                {
                    "type": "heading",
                    "content": "Adding All Values",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `sum()` function adds up all the numbers in a list."
                },
                {
                    "type": "code",
                    "content": "numbers = [10, 20, 30, 40]\ntotal = sum(numbers)\nprint(f\"The sum is {total}\")",
                    "properties": {
                        "language": "python",
                        "output": "The sum is 100"
                    }
                },
                {
                    "type": "text",
                    "content": "`sum()` added all the numbers: `10 + 20 + 30 + 40 = 100`."
                }
            ]
        },
        {
            "id": "sum_practical",
            "elements": [
                {
                    "type": "text",
                    "content": "`sum()` is useful for calculating totals like expenses, scores, or counts."
                },
                {
                    "type": "code",
                    "content": "expenses = [25, 50, 30, 45]\ntotal_spent = sum(expenses)\nprint(f\"Total spent: ${total_spent}\")",
                    "properties": {
                        "language": "python",
                        "output": "Total spent: $150"
                    }
                },
                {
                    "type": "text",
                    "content": "`sum()` calculated the total expenses as `$150`."
                }
            ]
        },
