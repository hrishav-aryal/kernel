                        "explanation": "copy() creates a new list, so changes to new_list don't affect original.",
                        "output": "[1, 2, 3]"
                    }
                }
            ]
        },
        {
            "id": "quick_check_copy_vs_reference",
            "elements": [
                {
                    "type": "text",
                    "content": "Which creates an independent copy?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "new_list = original",
                            "new_list = original.copy()",
                            "Both work the same"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! copy() creates an independent copy, while = creates a reference.",
                        "incorrectFeedback": "Use copy() to create an independent list. Using = creates a reference to the same list.",
                        "explanation": "copy() makes a new list, but = makes both variables point to the same list."
                    }
                }
            ]
        },
        {
            "id": "slicing_copy",
            "elements": [
                {
                    "type": "heading",
                    "content": "Alternative: Slicing",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Another way to copy a list is using slicing with `[:]`. This creates a new list with all items."
                },
                {
                    "type": "code",
                    "content": "original = [1, 2, 3]\ncopy = original[:]\n\ncopy.append(4)\nprint(f\"Original: {original}\")\nprint(f\"Copy: {copy}\")",
                    "properties": {
                        "language": "python",
                        "output": "Original: [1, 2, 3]\nCopy: [1, 2, 3, 4]"
                    }
                },
                {
                    "type": "text",
                    "content": "`[:]` creates a slice containing all items, which results in a new list."
                }
            ]
        },
        {
            "id": "when_to_copy",
            "elements": [
                {
                    "type": "text",
                    "content": "**When should you use copy()?**"
                },
                {
                    "type": "text",
                    "content": "Use `copy()` when you need to preserve the original list while making changes to a new version. This is common when creating backups, experimenting with modifications, or working with multiple versions of data."
                }
            ]
        },
