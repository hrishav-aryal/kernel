{
    "blocks": [
        {
            "id": "intro_finding",
            "elements": [
                {
                    "type": "heading",
                    "content": "Finding in Lists",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Sometimes you need to find the position of a specific item in a list. Python's `index()` method helps you locate where an item is."
                },
                {
                    "type": "text",
                    "content": "This is useful when you know what you're looking for and need to know where it is."
                }
            ]
        },
        {
            "id": "index_method",
            "elements": [
                {
                    "type": "heading",
                    "content": "The index() Method",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `index()` method finds the position (index) of the **first occurrence** of a value in a list."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nposition = fruits.index(\"banana\")\nprint(f\"Banana is at index {position}\")",
                    "properties": {
                        "language": "python",
                        "output": "Banana is at index 1"
                    }
                },
                {
                    "type": "text",
                    "content": "`index(\"banana\")` found that `\"banana\"` is at index `1`."
                }
            ]
        },
        {
            "id": "index_numbers",
            "elements": [
                {
                    "type": "text",
                    "content": "You can find the index of any value, including numbers."
                },
                {
                    "type": "code",
                    "content": "numbers = [10, 20, 30, 40]\nposition = numbers.index(30)\nprint(position)",
                    "properties": {
                        "language": "python",
                        "output": "2"
                    }
                },
                {
                    "type": "text",
                    "content": "The number `30` is at index `2` in the list."
                }
            ]
        },
        {
