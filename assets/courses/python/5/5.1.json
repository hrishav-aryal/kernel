        {
            "id": "reverse_sort",
            "elements": [
                {
                    "type": "heading",
                    "content": "Sorting in Descending Order",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "To sort from largest to smallest (descending order), use `sort(reverse=True)`."
                },
                {
                    "type": "code",
                    "content": "numbers = [5, 2, 8, 1, 9]\nnumbers.sort(reverse=True)\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "[9, 8, 5, 2, 1]"
                    }
                },
                {
                    "type": "text",
                    "content": "The list is now sorted from largest to smallest."
                }
            ]
        },
        {
            "id": "quick_check_reverse_sort",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Sort the list `scores` from highest to lowest score.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "scores = [78, 92, 85, 95]",
                                "indent": 0
                            },
                            {
                                "code": "scores.sort({1}={2})",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(scores)",
                                "indent": 0
