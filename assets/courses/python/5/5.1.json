                        "solutions": {
                            "1": "reverse",
                            "2": "True"
                        },
                        "hint": "Use sort(reverse=True) to sort in descending order.",
                        "correctFeedback": "Perfect! reverse=True sorts from largest to smallest.",
                        "incorrectFeedback": "Use sort(reverse=True) to sort in descending order.",
                        "explanation": "reverse=True changes the sort order to descending (largest to smallest).",
                        "output": "[95, 92, 85, 78]"
                    }
                }
            ]
        },
        {
            "id": "sorted_function",
            "elements": [
                {
                    "type": "heading",
                    "content": "The sorted() Function",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `sorted()` function creates a **new sorted list** without changing the original list."
                },
                {
                    "type": "code",
                    "content": "numbers = [5, 2, 8, 1]\nsorted_numbers = sorted(numbers)\nprint(f\"Original: {numbers}\")\nprint(f\"Sorted: {sorted_numbers}\")",
                    "properties": {
                        "language": "python",
                        "output": "Original: [5, 2, 8, 1]\nSorted: [1, 2, 5, 8]"
                    }
                },
                {
                    "type": "text",
                    "content": "The original list `numbers` remains unchanged, and we get a new sorted list."
                }
            ]
        },
        {
            "id": "sorted_vs_sort",
            "elements": [
                {
                    "type": "text",
                    "content": "**When to use which?**"
                },
                {
                    "type": "text",
                    "content": "Use `sort()` when you want to change the original list. Use `sorted()` when you need to keep the original list unchanged."
                }
            ]
        },
