    "blocks": [
        {
            "id": "intro_match_statements",
            "elements": [
                {
                    "type": "heading",
                    "content": "Match Statements",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "The `match` statement is a powerful way to check a value against multiple patterns. It's like a more elegant version of `if-elif-else` chains when you're comparing the same variable to different values."
                }
            ]
        },
        {
            "id": "basic_match_statement",
            "elements": [
                {
                    "type": "heading",
                    "content": "Basic Match Statement",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "A `match` statement starts with `match`, followed by the value you want to check, then `case` statements for each possible value."
                },
                {
                    "type": "text",
                    "content": "The `match` expression is evaluated once.\nThe value is compared with each `case`.\nIf a match is found, the corresponding code block runs."
                },
                {
                    "type": "code",
                    "content": "day = \"Monday\"\n\nmatch day:\n    case \"Monday\":\n        print(\"Start of work week\")\n    case \"Friday\":\n        print(\"TGIF!\")\n",
                    "properties": {
                        "language": "python",
                        "output": "Start of work week"
                    }
                }
            ]
        },
        {
            "id": "match_with_default",
            "elements": [
                {
                    "type": "text",
                    "content": "The `case _:` (underscore) is the default case that matches anything. It's like the `else` in an `if-elif-else` statement."
                },
                {
                    "type": "code",
                    "content": "grade = \"D\"\n\nmatch grade:\n    case \"A\":\n        print(\"Excellent!\")\n    case \"B\":\n        print(\"Good job!\")\n    case \"C\":\n        print(\"Not bad\")\n    case _:\n        print(\"Keep trying\")",
                    "properties": {
                        "language": "python",
                        "output": "Keep trying"
                    }
                }
            ]
        },
