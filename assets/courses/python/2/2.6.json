        {
            "id": "match_vs_if_elif",
            "elements": [
                {
                    "type": "text",
                    "content": "**Match statements** are cleaner when you're checking the same variable against multiple values."
                },
                {
                    "type": "text",
                    "content": "Let's look at both approaches for checking the color of a traffic light."
                }
            ]
        },
        {
            "id": "match_vs_if_elif",
            "elements": [
                {
                    "type": "text",
                    "content": "Using `if-elif-else`"
                },
                {
                    "type": "code",
                    "content": "color = \"red\"\n\nif color == \"red\":\n    print(\"Stop\")\nelif color == \"yellow\":\n    print(\"Slow down\")\nelif color == \"green\":\n    print(\"Go\")\nelse:\n    print(\"Unknown color\")",
                    "properties": {
                        "language": "python",
                        "output": "Stop"
                    }
                }
            ]
        },
        {
            "id": "match_vs_if_elif",
            "elements": [
                {
                    "type": "text",
                    "content": "Using `match`"
                },
                {
                    "type": "code",
                    "content": "color = \"red\"\n\nmatch color:\n    case \"red\":\n        print(\"Stop\")\n    case \"yellow\":\n        print(\"Slow down\")\n    case \"green\":\n        print(\"Go\")\n    case _:\n        print(\"Unknown color\")",
                    "properties": {
                        "language": "python",
                        "output": "Stop"
                    }
                }
            ]
        },
