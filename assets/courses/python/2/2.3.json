        {
            "id": "if_with_variables",
            "elements": [
                {
                    "type": "text",
                    "content": "You can use variables in if conditions. The condition can be any expression that evaluates to `True` or `False`."
                },
                {
                    "type": "code",
                    "content": "is_raining = True\nif is_raining:\n    print(\"Take an umbrella\")",
                    "properties": {
                        "language": "python",
                        "output": "Take an umbrella"
                    }
                }
            ]
        },
        {
            "id": "quick_check_basic_if",
            "elements": [
                {
