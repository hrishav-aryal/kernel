                        },
                        "hint": "Use if to check if it is raining.",
                        "correctFeedback": "Perfect! if is_raining checks if it is raining.",
                        "incorrectFeedback": "Use if to check if it is raining.",
                        "explanation": "if is_raining checks if it is raining.",
                        "output": "Take an umbrella"
                    }
                }
            ]
        },
        {
            "id": "quick_check_variable_condition",
            "elements": [
                {
                    "type": "text",
                    "content": "In order to drive a car, you need to be at least 16 years old."
                },
                {
                    "type": "code_fill",
                    "content": "Check if the user's age allows them to drive.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "age = 17",
                                "indent": 0
                            },
                            {
                                "code": "if age {1} 16:",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "    print(\"You can drive\")",
                                "indent": 0
                            }
                        ],
                        "options": [
                            ">=",
                            "==",
                            "!="
                        ],
                        "solutions": {
                            "1": ">="
                        },
                        "hint": "Use >= to check if age is greater than or equal to 16.",
                        "correctFeedback": "Great! age >= 16 checks if the person is old enough to drive.",
                        "incorrectFeedback": "Use >= to check if age is greater than or equal to 16.",
                        "explanation": "We use >= because you can drive if you are 16 or older.",
                        "output": "You can drive"
                    }
                }
            ]
        },
        {
            "id": "if_with_logical_operators",
            "elements": [
                {
                    "type": "text",
                    "content": "You can combine conditions using logical operators (`and`, `or`, `not`) in if statements."
                },
                {
                    "type": "code",
                    "content": "is_citizen = True\nage = 20\n\nif is_citizen and age >= 18:\n    print(\"You can vote!\")",
                    "properties": {
                        "language": "python",
                        "output": "You can vote!\nYou cannot vote"
                    }
                }
            ]
        },
