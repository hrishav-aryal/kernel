{
    "blocks": [
        {
            "id": "intro_if_statements",
            "elements": [
                {
                    "type": "heading",
                    "content": "If Statements",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "If statements let your program make decisions. They check if a condition is `True` and run code only when the condition is met."
                }
            ]
        },
        {
            "id": "basic_if",
            "elements": [
                {
                    "type": "heading",
                    "content": "Basic If Statement",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "An if statement starts with `if`, followed by a condition, then a colon `:`. The code that runs when the condition is `True` is indented."
                },
                {
                    "type": "code",
                    "content": "age = 20\nif age >= 18:\n    print(\"You are an adult\")",
                    "properties": {
                        "language": "python",
                        "output": "You are an adult"
                    }
                }
            ]
        },
        {
            "id": "if_with_false_condition",
            "elements": [
                {
                    "type": "text",
                    "content": "When the condition is `False`, the indented code is skipped."
                },
                {
                    "type": "code",
                    "content": "age = 16\nif age >= 18:\n    print(\"You are an adult\")\n\nprint(\"Program continues\")",
                    "properties": {
                        "language": "python",
                        "output": "Program continues"
                    }
                }
            ]
        },
        {
            "id": "indentation_importance",
            "elements": [
                {
                    "type": "heading",
                    "content": "Indentation is Important",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Python uses indentation (spaces or tabs) to show which code belongs inside the if statement. All code at the same indentation level runs together."
                },
                {
                    "type": "code",
                    "content": "temperature = 25\nif temperature > 20:\n    print(\"It's warm\")\n    print(\"Wear light clothes\")\n\nprint(\"Always check the weather\")",
                    "properties": {
                        "language": "python",
                        "output": "It's warm\nWear light clothes\nAlways check the weather"
                    }
                }
            ]
        },
        {
