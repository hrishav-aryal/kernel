        {
            "id": "types_and_comparisons",
            "elements": [
                {
                    "type": "text",
                    "content": "Always compare values of the same type for clearer results. Comparing numbers to strings is not meaningful because it will always return `False`."
                },
                {
                    "type": "text",
                    "content": "In order to compare a number to a string, we need to convert the string to a number first."
                },
                {
                    "type": "code",
                    "content": "print(5 == \"5\")\n\nprint(5 == int(\"5\"))",
                    "properties": {
                        "language": "python",
                        "output": "False\nTrue"
                    }
                }
            ]
        },
        {
            "id": "quick_check_convert_and_compare",
