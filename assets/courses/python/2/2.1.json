{
    "blocks": [
        {
            "id": "intro_comparisons",
            "elements": [
                {
                    "type": "heading",
                    "content": "Comparison Operators",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "We use comparison operators to compare values. A comparison produces a Boolean result: `True` or `False`."
                }
            ]
        },
        {
            "id": "equals_not_equals",
            "elements": [
                {
                    "type": "heading",
                    "content": "Equals and Not Equals",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "We can use double equals `==` to check if two values are equal, and use not equals `!=` to check if two values are not equal."
                },
                {
                    "type": "code",
                    "content": "print(5 == 5)\nprint(7 != 3)",
                    "properties": {
                        "language": "python",
                        "output": "True\nTrue"
                    }
                }
            ]
        },
        {
            "id": "greater_less_than",
            "elements": [
                {
                    "type": "heading",
                    "content": "Greater Than and Less Than",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `>` operator checks if the left value is greater than the right. The `<` operator checks if it's less than."
                },
                {
                    "type": "code",
                    "content": "print(10 > 4)\nprint(2 < 1)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                }
            ]
        },
        {
            "id": "greater_equal_less_equal",
            "elements": [
                {
                    "type": "heading",
                    "content": "Greater/Less Than or Equal",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `>=` operator checks if the left value is greater than or equal to the right. The `<=` operator checks if it's less than or equal."
                },
                {
                    "type": "code",
                    "content": "print(6 >= 6)\nprint(3 <= 2)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                }
            ]
        },
        {
            "id": "quick_check_equals_vs_assign",
            "elements": [
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "Which operator checks equality?",
                        "options": [
                            "=",
                            "=="
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! `==` checks if two values are equal.",
                        "incorrectFeedback": "Use `==` for comparison. `=` is assignment.",
                        "explanation": "`=` assigns a value to a variable. `==` compares two values."
                    }
                }
            ]
        },
