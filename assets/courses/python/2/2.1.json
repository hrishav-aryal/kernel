        {
            "id": "compare_strings_case",
            "elements": [
                {
                    "type": "text",
                    "content": "We can also use double equals `==` to compare strings. String comparisons are case-sensitive. Uppercase and lowercase are different."
                },
                {
                    "type": "code",
                    "content": "print(\"python\" == \"python\")\nprint(\"python\" == \"PYTHON\")",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                }
            ]
        },
