        {
            "id": "combining_operators",
            "elements": [
                {
                    "type": "text",
                    "content": "You can combine multiple logical operators in one expression. Python follows a specific order: `not` first, then `and`, then `or`."
                },
                {
                    "type": "code",
                    "content": "a = True\nb = False\nc = True\n\nresult = a and (b or not c)\nprint(result)",
                    "properties": {
                        "language": "python",
                        "output": "False"
                    }
                }
            ]
        },
