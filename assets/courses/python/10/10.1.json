        {
            "id": "creating_many_objects",
            "elements": [
                {
                    "type": "text",
                    "content": "You can create as many objects as you need from a single class. Each will have its own independent data."
                },
                {
                    "type": "code",
                    "content": "class Enemy:\n    pass\n\nenemy1 = Enemy()\nenemy1.name = \"Goblin\"\nenemy1.health = 50\n\nenemy2 = Enemy()\nenemy2.name = \"Orc\"\nenemy2.health = 100\n\nenemy3 = Enemy()\nenemy3.name = \"Dragon\"\nenemy3.health = 500)",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "text",
                    "content": "One `Enemy` class creates many different enemies. Each enemy has its own name and health value."
                }
            ]
        },
