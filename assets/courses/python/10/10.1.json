        },
        {
            "id": "practical_example",
            "elements": [
                {
                    "type": "text",
                    "content": "Here is a simple example of a `Person` class with attributes `name` and `age`."
                },
                {
                    "type": "code",
                    "content": "class Person:\n    pass\n\nperson1 = Person()\nperson1.name = \"Alice\"\nperson1.age = 25\n\nperson2 = Person()\nperson2.name = \"Bob\"\nperson2.age = 30\n\nprint(f\"{person1.name} is {person1.age}\")\nprint(f\"{person2.name} is {person2.age}\")",
                    "properties": {
                        "language": "python",
                        "output": "Alice is 25\nBob is 30"
                    }
                },
                {
                    "type": "text",
                    "content": "We created one `Person` class and used it to make two different people. This is the power of classes - one template, many objects!"
                }
            ]
        },
