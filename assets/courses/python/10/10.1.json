                            "2": "Car"
                        },
                        "hint": "Use class keyword followed by the class name.",
                        "correctFeedback": "Perfect! You created a class.",
                        "incorrectFeedback": "Use class ClassName: to define a class.",
                        "explanation": "The class keyword defines a new class, similar to how def defines functions.",
                        "output": ""
                    }
                }
            ]
        },
        {
            "id": "creating_objects",
            "elements": [
                {
                    "type": "heading",
                    "content": "Creating Objects",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "To create an object (instance) from a class, use the class name followed by parentheses `()`, similar to calling a function."
                },
                {
                    "type": "code",
                    "content": "class Car:\n    pass\n\ncar1 = Car()\ncar2 = Car()\n\nprint(type(car1))",
                    "properties": {
                        "language": "python",
                        "output": "<class '__main__.Car'>"
                    }
                },
                {
                    "type": "text",
                    "content": "We created two separate `Car` objects: `car1` and `car2`. The `type()` function shows they are instances of the `Car` class."
                }
            ]
        },
        {
