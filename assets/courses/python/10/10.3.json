        {
            "id": "self_in_init",
            "elements": [
                {
                    "type": "text",
                    "content": "Like other methods, `__init__` takes `self` as the first parameter, followed by any values you want to pass when creating the object."
                },
                {
                    "type": "code",
                    "content": "class Person:\n    def __init__(self, name, age, city):\n        self.name = name\n        self.age = age\n        self.city = city\n\nperson = Person(\"Alice\", 25, \"NYC\")\nprint(person.name)\nprint(person.age)\nprint(person.city)",
                    "properties": {
                        "language": "python",
                        "output": "Alice\n25\nNYC"
                    }
                },
                {
                    "type": "text",
                    "content": "The parameters after `self` become the values you pass when creating objects: `Person(\"Alice\", 25, \"NYC\")`."
                }
            ]
        },
