                        "output": "Meow!"
                    }
                }
            ]
        },
        {
            "id": "understanding_self",
            "elements": [
                {
                    "type": "heading",
                    "content": "Understanding Self",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`self` represents the specific object that's calling the method."
                },
                {
                    "type": "text",
                    "content": "Let's see how `self` lets methods work with object data:"
                },
                {
                    "type": "code",
                    "content": "class Dog:\n    def set_name(self, name):\n        self.name = name\n\ndog = Dog()\ndog.set_name(\"Buddy\")\nprint(dog.name)",
                    "properties": {
                        "language": "python",
                        "output": "Buddy"
                    }
                },
                {
                    "type": "text",
                    "content": "When we call `dog.set_name(\"Buddy\")`, Python automatically passes `dog` as `self` to the method. Inside the method, `self.name = name` means \"store this `name` in the `dog` object that called me\"."
                }
            ]
        },
        {
            "id": "self_with_multiple_objects",
            "elements": [
                {
                    "type": "text",
                    "content": "**Self keeps objects separate**"
                },
                {
                    "type": "text",
                    "content": "Each object uses `self` to access its own data, not other objects' data:"
                },
                {
                    "type": "code",
                    "content": "class Dog:\n    def set_name(self, name):\n        self.name = name\n    \n    def greet(self):\n        print(f\"Hi, I'm {self.name}!\")\n\ndog1 = Dog()\ndog1.set_name(\"Buddy\")\n\ndog2 = Dog()\ndog2.set_name(\"Max\")\n\ndog1.greet()\ndog2.greet()",
                    "properties": {
                        "language": "python",
                        "output": "Hi, I'm Buddy!\nHi, I'm Max!"
                    }
                },
                {
                    "type": "text",
                    "content": "When `dog1.greet()` runs, `self` refers to `dog1`. When `dog2.greet()` runs, `self` refers to `dog2`. Each object accesses its own name through `self`."
                },
                {
                    "type": "text",
                    "content": "Notice how we can access the `name` attribute using `self.name` in the `greet` method."
                }
            ]
        },
        {
            "id": "quick_check_self",
            "elements": [
                {
                    "type": "text",
                    "content": "What does `self` represent in a method?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "The class itself",
                            "The specific object calling the method",
                            "All objects of that class"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! self refers to the specific object.",
                        "incorrectFeedback": "self represents the individual object that called the method.",
                        "explanation": "self lets methods access and modify the calling object's attributes."
                    }
                }
            ]
        },
        {
            "id": "methods_modifying_attributes",
            "elements": [
                {
                    "type": "heading",
                    "content": "Methods Can Change Attributes",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Methods can read and modify the object's attributes using `self`:"
                },
                {
                    "type": "code",
                    "content": "class Counter:\n    def start(self):\n        self.count = 0\n    \n    def increment(self):\n        self.count = self.count + 1\n    \n    def show(self):\n        print(f\"Count: {self.count}\")\n\nc = Counter()\nc.start()\nc.increment()\nc.increment()\nc.show()",
                    "properties": {
                        "language": "python",
                        "output": "Count: 2"
                    }
                },
                {
                    "type": "list",
                    "content": "",
                    "properties": {
                        "numbered": true,
                        "items": [
                            "`c.start()` creates a `count` attribute and sets it to `0`",
                            "First `c.increment()` adds 1 to `count`",
                            "Second `c.increment()` adds 1 to `count` again",
                            "`c.show()` reads and prints the current `count` value"
                        ]
                    }
                },
                {
                    "type": "text",
                    "content": "All methods work with the same `count` attribute through `self`. The object remembers its data between method calls!"
                }
            ]
        },
        {
