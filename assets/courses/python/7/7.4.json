                        "hint": "Set default value with times = 1.",
                        "correctFeedback": "Perfect! The function repeats the message once by default.",
                        "incorrectFeedback": "Use times = 1 to set the default value.",
                        "explanation": "Default parameters make functions more convenient to use.",
                        "output": "Hello"
                    }
                }
            ]
        },
