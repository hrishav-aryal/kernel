                            {
                                "code": "",
                                "indent": 0
                            },
                            {
                                "code": "repeat_message(\"Hello\")",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "times = 1",
                            "message"
                        ],
                        "solutions": {
