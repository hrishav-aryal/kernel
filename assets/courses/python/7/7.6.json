        {
            "id": "practical_example",
            "elements": [
                {
                    "type": "text",
                    "content": "Let's create a practical function with conditionals."
                },
                {
                    "type": "code",
                    "content": "def calculate_shipping(price, is_member):\n    if price >= 50:\n        return 0\n    elif is_member:\n        return 5\n    else:\n        return 10\n\nprint(f\"Shipping: ${calculate_shipping(30, True)}\")\nprint(f\"Shipping: ${calculate_shipping(60, False)}\")",
                    "properties": {
                        "language": "python",
                        "output": "Shipping: $5\nShipping: $0"
                    }
                },
                {
                    "type": "text",
                    "content": "The function returns different shipping costs based on conditions."
                }
            ]
        },
