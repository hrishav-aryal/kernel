        {
            "id": "multiple_parameters_conditionals",
            "elements": [
                {
                    "type": "text",
                    "content": "You can combine multiple parameters with conditionals for complex logic."
                },
                {
                    "type": "code",
                    "content": "def can_vote(age, is_citizen):\n    if age >= 18 and is_citizen:\n        return True\n    else:\n        return False\n\nprint(can_vote(20, True))\nprint(can_vote(20, False))",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                },
                {
                    "type": "text",
                    "content": "The function checks multiple conditions before returning."
                }
            ]
        },
