                {
                    "type": "code_fill",
                    "content": "Complete the function to count how many items are in the list.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "def count_items(items):",
                                "indent": 0
                            },
                            {
                                "code": "    count = 0",
                                "indent": 0
