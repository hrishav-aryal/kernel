        },
        {
            "id": "return_vs_print",
            "elements": [
                {
                    "type": "heading",
                    "content": "Return vs Print",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`return` and `print` are different. `print` shows output, but `return` gives a value back to use in your code."
                },
                {
                    "type": "code",
                    "content": "def add_with_print(a, b):\n    print(a + b)\n\ndef add_with_return(a, b):\n    return a + b\n\nresult1 = add_with_print(5, 3)\nprint(f\"Result1: {result1}\")\n\nresult2 = add_with_return(5, 3)\nprint(f\"Result2: {result2}\")",
                    "properties": {
                        "language": "python",
                        "output": "8\nResult1: None\nResult2: 8"
                    }
                },
                {
                    "type": "text",
                    "content": "`print` just displays. `return` gives back a value you can use."
                }
            ]
        },
        {
            "id": "quick_check_vs_print",
            "elements": [
                {
                    "type": "text",
                    "content": "What's the difference between return and print?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "They do the same thing",
                            "return sends a value back, print displays output",
                            "print is faster"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! return gives a value back to use, print just displays.",
                        "incorrectFeedback": "return sends a value back, while print just displays output.",
                        "explanation": "Use return when you need the value for calculations or storage."
                    }
                }
            ]
        },
        {
            "id": "return_ends_function",
            "elements": [
                {
                    "type": "text",
                    "content": "**Important:** `return` immediately exits the function. Any code after `return` won't run."
                },
                {
                    "type": "code",
                    "content": "def check_age(age):\n    return age >= 18\n    print(\"This won't print\")\n\nresult = check_age(20)\nprint(result)",
                    "properties": {
                        "language": "python",
                        "output": "True"
                    }
                },
                {
                    "type": "text",
                    "content": "The function returns immediately, so the print statement never runs."
                }
            ]
        },
        {
            "id": "quick_check_exit",
            "elements": [
                {
                    "type": "text",
                    "content": "What will this code print?"
                },
                {
                    "type": "code",
                    "content": "def test():\n    print(\"First\")\n    return 10\n    print(\"Second\")\n\ntest()",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "First\n10\nSecond",
                            "First",
                            "First\nSecond"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! return exits the function, so \"Second\" never prints.",
                        "incorrectFeedback": "return exits the function immediately.",
                        "explanation": "After return, the function exits and the rest of the code doesn't run."
                    }
                }
            ]
        },
        {
            "id": "return_expressions",
            "elements": [
                {
                    "type": "text",
                    "content": "You can return expressions directly without storing them in a variable first."
                },
                {
                    "type": "code",
                    "content": "def double(num):\n    return num * 2\n\ndef is_adult(age):\n    return age >= 18\n\nprint(double(7))\nprint(is_adult(20))",
                    "properties": {
                        "language": "python",
                        "output": "14\nTrue"
                    }
                },
                {
                    "type": "text",
                    "content": "You can return calculations, comparisons, or any expression."
                }
            ]
        },
