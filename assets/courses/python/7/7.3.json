        {
            "id": "functions_without_return",
            "elements": [
                {
                    "type": "text",
                    "content": "Functions without a `return` statement automatically return `None`."
                },
                {
                    "type": "code",
                    "content": "def say_hello():\n    print(\"Hello!\")\n\nresult = say_hello()\nprint(f\"Result: {result}\")",
                    "properties": {
                        "language": "python",
                        "output": "Hello!\nResult: None"
                    }
                },
                {
                    "type": "text",
                    "content": "Since there's no return, the function returns `None` by default."
                }
            ]
        },
