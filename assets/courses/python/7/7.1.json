                        "incorrectFeedback": "Use descriptive lowercase names with underscores.",
                        "explanation": "Function names should be descriptive and use lowercase with underscores."
                    }
                }
            ]
        },
        {
            "id": "multiple_functions",
            "elements": [
                {
                    "type": "text",
                    "content": "You can create multiple functions in your program. Each function does its own specific task."
                },
                {
                    "type": "code",
                    "content": "def greet_morning():\n    print(\"Good morning!\")\n\ndef greet_evening():\n    print(\"Good evening!\")\n\ngreet_morning()\ngreet_evening()",
                    "properties": {
                        "language": "python",
                        "output": "Good morning!\nGood evening!"
                    }
                },
                {
                    "type": "text",
                    "content": "Each function handles a different greeting."
                }
            ]
        },
