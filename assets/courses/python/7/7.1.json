        {
            "id": "defining_vs_calling",
            "elements": [
                {
                    "type": "text",
                    "content": "**Important:** Defining a function doesn't run it. You must call it to execute the code."
                },
                {
                    "type": "code",
                    "content": "def say_hello():\n    print(\"Hello!\")\n\n# Function is defined but not called yet\n# Nothing prints until we call it\nsay_hello()",
                    "properties": {
                        "language": "python",
                        "output": "Hello!"
                    }
                },
                {
                    "type": "text",
                    "content": "The code only runs when `say_hello()` is called."
                }
            ]
        },
