{
    "blocks": [
        {
            "id": "intro_parameters",
            "elements": [
                {
                    "type": "heading",
                    "content": "Parameters",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Parameters let you pass information **into** a function. This makes functions more flexible because they can work with different values."
                },
                {
                    "type": "text",
                    "content": "Think of parameters as placeholders that get filled with actual values when you call the function."
                }
            ]
        },
        {
            "id": "adding_parameters",
            "elements": [
                {
                    "type": "heading",
                    "content": "Adding Parameters",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "To add a parameter, put a variable name inside the parentheses when defining the function."
                },
                {
                    "type": "code",
                    "content": "def greet(name):\n    print(f\"Hello, {name}!\")\n\ngreet(\"Alice\")",
                    "properties": {
                        "language": "python",
                        "output": "Hello, Alice!"
                    }
                },
                {
                    "type": "text",
                    "content": "`name` is a parameter. When we call `greet(\"Alice\")`, the value `\"Alice\"` is passed to `name`."
                }
            ]
        },
        {
            "id": "using_parameters",
            "elements": [
                {
                    "type": "text",
                    "content": "Inside the function, you can use the parameter like any other variable."
                },
                {
                    "type": "code",
                    "content": "def welcome(username):\n    print(f\"Welcome, {username}!\")\n    print(\"Glad to have you here.\")\n\nwelcome(\"Bob\")",
                    "properties": {
                        "language": "python",
                        "output": "Welcome, Bob!\nGlad to have you here."
                    }
                },
                {
                    "type": "text",
                    "content": "The parameter `username` is used inside the function with the value `\"Bob\"`."
                }
            ]
        },
        {
