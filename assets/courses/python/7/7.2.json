                    }
                }
            ]
        },
        {
            "id": "different_values",
            "elements": [
                {
                    "type": "text",
                    "content": "You can call the same function with different values. This is what makes functions powerful!"
                },
                {
                    "type": "code",
                    "content": "def greet(name):\n    print(f\"Hello, {name}!\")\n\ngreet(\"Alice\")\ngreet(\"Bob\")\ngreet(\"Charlie\")",
                    "properties": {
                        "language": "python",
                        "output": "Hello, Alice!\nHello, Bob!\nHello, Charlie!"
                    }
                },
                {
                    "type": "text",
                    "content": "Same function, different results based on the input!"
                }
            ]
        },
        {
            "id": "quick_check_different_values",
            "elements": [
                {
                    "type": "text",
                    "content": "What makes parameters useful?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "They make functions longer",
                            "They let functions work with different values",
                            "They are required for all functions"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! Parameters make functions flexible by accepting different inputs.",
                        "incorrectFeedback": "Parameters allow functions to work with different values.",
                        "explanation": "Parameters let you pass different data to functions, making them reusable."
                    }
                }
            ]
        },
        {
            "id": "multiple_parameters",
            "elements": [
                {
                    "type": "heading",
                    "content": "Multiple Parameters",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Functions can have multiple parameters. Separate them with commas."
                },
                {
                    "type": "code",
                    "content": "def introduce(name, age):\n    print(f\"My name is {name}\")\n    print(f\"I am {age} years old\")\n\nintroduce(\"Alice\", 25)",
                    "properties": {
                        "language": "python",
                        "output": "My name is Alice\nI am 25 years old"
                    }
                },
                {
                    "type": "text",
                    "content": "The function takes two parameters: `name` and `age`."
                }
            ]
        },
        {
            "id": "parameter_order",
            "elements": [
                {
                    "type": "text",
                    "content": "**Order matters!** Parameters are matched by position when you call the function."
                },
                {
                    "type": "code",
                    "content": "def show_info(first, second):\n    print(f\"First: {first}\")\n    print(f\"Second: {second}\")\n\nshow_info(\"A\", \"B\")",
                    "properties": {
                        "language": "python",
                        "output": "First: A\nSecond: B"
                    }
                },
                {
                    "type": "text",
                    "content": "The first value `\"A\"` goes to `first`, the second value `\"B\"` goes to `second`."
                }
            ]
        },
        {
