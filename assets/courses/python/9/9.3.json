                        "explanation": "pow(x, y) calculates x raised to the power of y.",
                        "output": "81.0"
                    }
                }
            ]
        },
        {
            "id": "pi_constant",
            "elements": [
                {
                    "type": "heading",
                    "content": "Math Constants",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The math module provides useful constants like `pi` (π ≈ 3.14159...)."
                },
                {
                    "type": "code",
                    "content": "import math\n\nradius = 5\narea = math.pi * math.pow(radius, 2)\n\nprint(f\"Area: {area}\")",
                    "properties": {
                        "language": "python",
                        "output": "Area: 78.53981633974483"
                    }
                },
                {
                    "type": "text",
                    "content": "We used `math.pi` to calculate the area of a circle. Note: `pi` is a value, not a function, so no parentheses!"
                }
            ]
        },
        {
            "id": "other_constants",
            "elements": [
                {
                    "type": "text",
                    "content": "The math module also provides other useful constants like `e` (Euler's number), `tau` (2π), and `inf` (infinity)."
                }
            ]
        },
        {
            "id": "quick_check_pi",
            "elements": [
                {
                    "type": "text",
