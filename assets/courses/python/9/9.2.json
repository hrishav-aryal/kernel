                }
            ]
        },
        {
            "id": "shuffle_function",
            "elements": [
                {
                    "type": "heading",
                    "content": "Shuffling Lists",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`shuffle()` randomly rearranges all items in a list. This changes the original list."
                },
                {
                    "type": "code",
                    "content": "import random\n\ncards = [\"A\", \"K\", \"Q\", \"J\"]\nprint(f\"Before: {cards}\")\n\nrandom.shuffle(cards)\nprint(f\"After: {cards}\")",
                    "properties": {
                        "language": "python",
                        "output": "Before: ['A', 'K', 'Q', 'J']\nAfter: ['Q', 'A', 'J', 'K']"
                    }
                },
                {
                    "type": "text",
                    "content": "Perfect for card games or randomizing any list order. The list itself is modified."
                }
            ]
        },
        {
