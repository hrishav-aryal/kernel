        {
            "id": "random_vs_choice",
            "elements": [
                {
                    "type": "text",
                    "content": "**Quick comparison**"
                },
                {
                    "type": "list",
                    "content": "",
                    "properties": {
                        "numbered": false,
                        "items": [
                            "`randint(a, b)` - Random number in a range",
                            "`choice(list)` - One random item from a list",
                            "`shuffle(list)` - Rearrange all items randomly"
                        ]
                    }
                }
            ]
        },
