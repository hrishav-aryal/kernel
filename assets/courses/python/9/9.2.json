                }
            ]
        },
        {
            "id": "choice_function",
            "elements": [
                {
                    "type": "heading",
                    "content": "Making Random Choices",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`choice()` picks a random item from a list."
                },
                {
                    "type": "code",
                    "content": "import random\n\ncolors = [\"red\", \"blue\", \"green\", \"yellow\"]\nchosen = random.choice(colors)\nprint(f\"Random color: {chosen}\")",
                    "properties": {
                        "language": "python",
                        "output": "Random color: green"
                    }
                },
                {
                    "type": "text",
                    "content": "Each item in the list has an equal chance of being picked."
                }
            ]
        },
        {
            "id": "choice_examples",
            "elements": [
                {
                    "type": "text",
                    "content": "You can use `choice()` with any list - strings, numbers, or anything else."
                },
                {
                    "type": "code",
                    "content": "import random\n\nactions = [\"jump\", \"run\", \"hide\"]\naction = random.choice(actions)\n\nprint(f\"Action: {action}\")",
                    "properties": {
                        "language": "python",
                        "output": "Action: run"
                    }
                },
                {
                    "type": "text",
                    "content": "Great for games where you need to randomly select actions, names, or options."
                }
            ]
        },
        {
            "id": "quick_check_choice",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Pick a random item from the list.",
                    "properties": {
