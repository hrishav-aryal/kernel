        {
            "id": "intro_random",
            "elements": [
                {
                    "type": "heading",
                    "content": "Random Module",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "The `random` module helps you generate random numbers and make random choices. Perfect for games, simulations, and adding unpredictability!"
                },
                {
                    "type": "text",
                    "content": "Let's explore the most useful functions from this module."
                }
            ]
        },
        {
            "id": "randint_function",
            "elements": [
                {
                    "type": "heading",
                    "content": "Getting Random Numbers",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`randint(a, b)` gives you a random integer between `a` and `b`, including both endpoints."
                },
                {
                    "type": "code",
                    "content": "import random\n\ndice = random.randint(1, 6)\nprint(f\"You rolled: {dice}\")",
                    "properties": {
                        "language": "python",
                        "output": "You rolled: 4"
                    }
                },
                {
                    "type": "text",
                    "content": "This simulates rolling a 6-sided die. Each run gives a different number from `1` to `6`."
                }
            ]
        },
        {
            "id": "randint_range",
            "elements": [
                {
                    "type": "text",
                    "content": "You can use any range of numbers you need."
                },
                {
                    "type": "code",
                    "content": "import random\n\nage = random.randint(18, 100)\ntemp = random.randint(-10, 40)\n\nprint(f\"Age: {age}\")\nprint(f\"Temperature: {temp}°C\")",
                    "properties": {
                        "language": "python",
                        "output": "Age: 67\nTemperature: 23°C"
                    }
                },
                {
                    "type": "text",
                    "content": "Each number in the range has an equal chance of being selected."
                }
            ]
        },
        {
