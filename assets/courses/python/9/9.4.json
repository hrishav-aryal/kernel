                        "correctFeedback": "Perfect! You got today's date.",
                        "incorrectFeedback": "Use date.today() to get the current date.",
                        "explanation": "today() returns the current date from your system.",
                        "output": "2025"
                    }
                }
            ]
        },
        {
            "id": "creating_dates",
            "elements": [
                {
                    "type": "heading",
                    "content": "Creating Specific Dates",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can create any date using `date(year, month, day)`."
                },
                {
                    "type": "code",
                    "content": "from datetime import date\n\nbirthday = date(2000, 5, 15)\nprint(birthday)",
                    "properties": {
                        "language": "python",
                        "output": "2000-05-15"
                    }
                },
                {
                    "type": "text",
                    "content": "Create dates by providing year, month, and day as numbers."
                }
            ]
        },
        {
            "id": "quick_check_create_date",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Create a date for Christmas.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "from datetime import date",
                                "indent": 0
                            },
                            {
                                "code": "",
                                "indent": 0
                            },
                            {
                                "code": "christmas = {1}(2050, 12, 25)",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "print(christmas)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "datetime",
                            "date"
                        ],
                        "solutions": {
                            "1": "date"
                        },
                        "hint": "Use date(year, month, day) to create a specific date.",
                        "correctFeedback": "Perfect! You created a specific date.",
                        "incorrectFeedback": "Use date(year, month, day) to create a specific date.",
                        "explanation": "date() takes year, month, and day in that order.",
                        "output": "2050-12-25"
                    }
                }
            ]
        },
        {
            "id": "datetime_now",
            "elements": [
                {
                    "type": "heading",
                    "content": "Working with Time",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`datetime.now()` gives you the current date **and** time."
                },
                {
                    "type": "code",
                    "content": "from datetime import datetime\n\nnow = datetime.now()\nprint(now)",
                    "properties": {
                        "language": "python",
                        "output": "2025-10-29 14:30:45.123456"
                    }
                },
                {
                    "type": "text",
                    "content": "This includes year, month, day, hour, minute, second, and microseconds."
                }
            ]
        },
        {
            "id": "datetime_parts",
            "elements": [
                {
                    "type": "text",
                    "content": "You can access time parts using the `hour`, `minute`, `second`, and `microsecond` attributes just like date parts."
                },
                {
                    "type": "code",
                    "content": "from datetime import datetime\n\nnow = datetime.now()\n\nprint(f\"Hour: {now.hour}\")\nprint(f\"Minute: {now.minute}\")\nprint(f\"Second: {now.second}\")",
                    "properties": {
                        "language": "python",
                        "output": "Hour: 14\nMinute: 30\nSecond: 45"
                    }
                },
                {
                    "type": "text",
                    "content": "Access hour, minute, and second as individual numbers. Time uses 24-hour format."
                }
            ]
        },
        {
            "id": "quick_check_datetime",
            "elements": [
                {
                    "type": "text",
                    "content": "What's the difference between date.today() and datetime.now()?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "They are the same",
                            "today() gives date only, now() gives date and time",
                            "today() is faster"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! today() is date only, now() includes time.",
                        "incorrectFeedback": "today() gives just the date, now() includes the time too.",
                        "explanation": "Use today() for dates, now() when you need the time as well."
                    }
                }
            ]
        },
        {
            "id": "formatting_dates",
            "elements": [
                {
                    "type": "text",
                    "content": "You can format dates as readable strings using `strftime()`."
                },
                {
                    "type": "text",
                    "content": "The `strftime()` method takes a format string as an argument and returns a string with the formatted date."
                },
                {
                    "type": "code",
                    "content": "from datetime import date\n\ntoday = date(2050, 12, 25)\n\nformatted = today.strftime(\"%B %d, %Y\")\nprint(formatted)",
                    "properties": {
                        "language": "python",
                        "output": "December 25, 2050"
                    }
                },
                {
                    "type": "text",
                    "content": "Here we formatted the date to show the full month name, day, and year using the `\"%B %d, %Y\"` format string."
                },
                {
                    "type": "text",
                    "content": "`%B` = full month name, `%d` = day, `%Y` = full year."
                }
            ]
        },
        {
            "id": "format_codes",
            "elements": [
                {
                    "type": "text",
                    "content": "Common format codes"
                },
                {
                    "type": "list",
                    "content": "",
                    "properties": {
                        "numbered": false,
                        "items": [
                            "`%Y` - Year (2050)",
                            "`%m` - Month as number (12)",
                            "`%d` - Day (25)",
                            "`%B` - Full month name (December)",
                            "`%A` - Full day name (Friday)"
                        ]
                    }
                }
            ]
        },
