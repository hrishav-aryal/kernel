    "blocks": [
        {
            "id": "intro_datetime",
            "elements": [
                {
                    "type": "heading",
                    "content": "Datetime Module",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "The `datetime` module helps you work with dates and times. Perfect for timestamps, scheduling, and tracking events!"
                },
                {
                    "type": "text",
                    "content": "Let's explore how to work with dates and times in Python."
                }
            ]
        },
        {
            "id": "getting_today",
            "elements": [
                {
                    "type": "heading",
                    "content": "Getting Today's Date",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "`date.today()` gives you today's date."
                },
                {
                    "type": "code",
                    "content": "from datetime import date\n\ntoday = date.today()\nprint(today)",
                    "properties": {
                        "language": "python",
                        "output": "2025-10-29"
                    }
                },
                {
                    "type": "text",
                    "content": "First we import the `date` class from the `datetime` module. Then we call the `today()` method to get the current date."
                },
                {
                    "type": "text",
                    "content": "The date is shown in the format: **year-month-day**. This is the standard international format."
                }
            ]
        },
        {
            "id": "date_parts",
            "elements": [
                {
                    "type": "text",
                    "content": "You can access individual parts of a date: year, month, and day using the `year`, `month`, and `day` attributes."
                },
                {
                    "type": "code",
                    "content": "from datetime import date\n\ntoday = date.today()\n\nprint(f\"Year: {today.year}\")\nprint(f\"Month: {today.month}\")\nprint(f\"Day: {today.day}\")",
                    "properties": {
                        "language": "python",
                        "output": "Year: 2025\nMonth: 10\nDay: 29"
                    }
                },
                {
                    "type": "text",
                    "content": "Each part is a number you can use in calculations or comparisons."
                }
            ]
        },
        {
            "id": "quick_check_today",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Get today's date and print the `year`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "from datetime import date",
                                "indent": 0
                            },
                            {
                                "code": "",
                                "indent": 0
                            },
                            {
                                "code": "today = date.{1}()",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "print(today.year)",
                                "indent": 0
                            }
                        ],
