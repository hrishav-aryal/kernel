        {
            "id": "practical_example",
            "elements": [
                {
                    "type": "text",
                    "content": "Let's see a practical example combining what you've learned."
                },
                {
                    "type": "code",
                    "content": "def safe_divide(a, b):\n    try:\n        result = a / b\n        return result\n    except ZeroDivisionError:\n        return \"Cannot divide by zero\"\n    except TypeError:\n        return \"Invalid input types\"\n\nprint(safe_divide(10, 2))\nprint(safe_divide(10, 0))\nprint(safe_divide(10, \"two\"))",
                    "properties": {
                        "language": "python",
                        "output": "5.0\nCannot divide by zero\nInvalid input types"
                    }
                },
                {
                    "type": "text",
                    "content": "The function handles different errors gracefully and returns helpful messages."
                }
            ]
        },
