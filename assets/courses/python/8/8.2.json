        {
            "id": "getting_error_info",
            "elements": [
                {
                    "type": "text",
                    "content": "You can store the error information in a variable using `as` to display helpful details."
                },
                {
                    "type": "code",
                    "content": "try:\n    number = int(\"hello\")\nexcept ValueError as error:\n    print(f\"Error occurred: {error}\")",
                    "properties": {
                        "language": "python",
                        "output": "Error occurred: invalid literal for int() with base 10: 'hello'"
                    }
                },
                {
                    "type": "text",
                    "content": "The `as error` part captures the error details so you can display or log them."
                }
            ]
        },
