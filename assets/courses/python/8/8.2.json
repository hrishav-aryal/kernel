        {
            "id": "multiple_except",
            "elements": [
                {
                    "type": "heading",
                    "content": "Multiple Except Blocks",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can have multiple `except` blocks to handle different errors differently."
                },
                {
                    "type": "code",
                    "content": "try:\n    numbers = [1, 2, 3]\n    index = int(\"five\")\n    print(numbers[index])\nexcept ValueError:\n    print(\"Invalid number format\")\nexcept IndexError:\n    print(\"Index out of range\")",
                    "properties": {
                        "language": "python",
                        "output": "Invalid number format"
                    }
                },
                {
                    "type": "text",
                    "content": "Python tries each except block in order and runs the first one that matches."
                }
            ]
        },
