                }
            ]
        },
        {
            "id": "choosing_error_type",
            "elements": [
                {
                    "type": "text",
                    "content": "Choose the error type that best describes the problem:"
                },
                {
                    "type": "list",
                    "content": "",
                    "properties": {
                        "numbered": false,
                        "items": [
                            "**ValueError:** Invalid value (wrong range, format)",
                            "**TypeError:** Wrong data type",
                            "**KeyError:** Dictionary key doesn't exist",
                            "**IndexError:** List index out of range"
                        ]
                    }
                },
                {
                    "type": "text",
                    "content": "Using the right error type helps others understand what went wrong."
                }
            ]
        },
        {
            "id": "value_error_example",
            "elements": [
                {
                    "type": "code",
                    "content": "def set_age(age):\n    if age < 0:\n        raise ValueError(\"Age cannot be negative\")\n    print(f\"Age set to: {age}\")\n\nset_age(30)\nset_age(-5)",
                    "properties": {
                        "language": "python",
                        "output": "Age set to: 30"
                    }
                },
                {
                    "type": "text",
                    "content": "This function checks that age is not negative. If it is, it raises a ValueError to indicate invalid input."
                }
            ]
        },
        {
            "id": "quick_check_error_type",
            "elements": [
                {
                    "type": "text",
                    "content": "What error type should you raise for a value that's the wrong type?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "ValueError",
                            "TypeError",
                            "KeyError"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! TypeError is for wrong data types.",
                        "incorrectFeedback": "Use TypeError when the data type is wrong.",
                        "explanation": "TypeError indicates the value is the wrong type, like passing a string instead of a number."
                    }
                }
            ]
        },
        {
            "id": "raising_in_functions",
            "elements": [
                {
                    "type": "text",
                    "content": "Raising errors in functions makes them safer by checking inputs before processing."
                },
                {
                    "type": "code",
                    "content": "def divide(a, b):\n    if b == 0:\n        raise ValueError(\"Can't divide by zero\")\n    return a / b\n\nprint(divide(10, 2))\nprint(divide(20, 4))",
                    "properties": {
                        "language": "python",
                        "output": "5.0\n5.0"
                    }
                },
                {
                    "type": "text",
                    "content": "Before dividing, the function checks if `b` is zero. If it is, it raises an error to prevent the crash."
                }
            ]
        },
        {
            "id": "quick_check_validation",
            "elements": [
