                        "explanation": "finally is guaranteed to run, making it perfect for cleanup tasks."
                    }
                }
            ]
        },
        {
            "id": "practical_uses",
            "elements": [
                {
                    "type": "text",
                    "content": "**Common uses for finally:**"
                },
                {
                    "type": "list",
                    "content": "",
                    "properties": {
                        "numbered": false,
                        "items": [
                            "Closing files",
                            "Closing database connections",
                            "Releasing resources",
                            "Logging that an operation finished"
                        ]
                    }
                },
                {
                    "type": "text",
                    "content": "Anything that must happen regardless of success or failure belongs in `finally`."
                }
            ]
        },
        {
            "id": "complete_structure",
            "elements": [
                {
                    "type": "text",
                    "content": "Here's the complete error handling structure with all four blocks `try`, `except`, `else`, and `finally`:"
                },
                {
                    "type": "code",
                    "content": "try:\n    value = int(\"42\")\n    result = 100 / value\nexcept ValueError:\n    print(\"Invalid number\")\nexcept ZeroDivisionError:\n    print(\"Cannot divide by zero\")\nelse:\n    print(f\"Success! Result: {result}\")\nfinally:\n    print(\"Operation completed\")",
                    "properties": {
                        "language": "python",
                        "output": "Success! Result: 2.38\nOperation completed"
                    }
                },
                {
                    "type": "text",
                    "content": "**Order matters:** `try` → `except` → `else` → `finally`. You don't need all of them - use what you need."
                }
            ]
        },
