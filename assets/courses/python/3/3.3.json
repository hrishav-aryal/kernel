            "elements": [
                {
                    "type": "text",
                    "content": "You can loop through strings too. Each character in the string becomes an item in the sequence."
                },
                {
                    "type": "code",
                    "content": "word = \"hello\"\nfor letter in word:\n    print(f\"Letter: {letter}\")",
