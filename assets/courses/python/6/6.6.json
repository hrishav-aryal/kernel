                    }
                }
            ]
        },
        {
            "id": "empty_set",
            "elements": [
                {
                    "type": "text",
                    "content": "To create an empty set, use `set()`. You **cannot** use `{}` because that creates an empty dictionary."
                },
                {
                    "type": "code",
                    "content": "empty_set = set()\nprint(empty_set)\nprint(type(empty_set))",
                    "properties": {
                        "language": "python",
                        "output": "set()\n<class 'set'>"
                    }
                },
                {
                    "type": "text",
                    "content": "Use `set()` to create an empty set, ready to add items later."
                }
            ]
        },
