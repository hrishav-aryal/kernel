                        ],
                        "options": [
                            "delete",
                            "discard",
                            "remove"
                        ],
                        "solutions": {
                            "1": "remove"
                        },
                        "hint": "Use remove() to delete an item from the set.",
                        "correctFeedback": "Perfect! remove() deleted the item from the set.",
                        "incorrectFeedback": "Use remove(2) to delete the item.",
                        "explanation": "remove() deletes the specified item from the set.",
                        "output": "{1, 3, 4}"
                    }
                }
            ]
        },
        {
            "id": "quick_check_discard",
            "elements": [
                {
                    "type": "text",
                    "content": "Which method is safer when you're not sure if an item exists?"
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "remove()",
                            "discard()",
                            "delete()"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! discard() won't cause an error if the item doesn't exist.",
                        "incorrectFeedback": "Use discard() to safely remove items that might not exist.",
                        "explanation": "discard() is safer because it doesn't raise an error for missing items."
                    }
                }
            ]
        },
        {
            "id": "checking_membership",
            "elements": [
                {
                    "type": "heading",
                    "content": "Checking Membership",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Use the `in` operator to check if an item exists in a set. This is very fast with sets!"
                },
                {
                    "type": "code",
                    "content": "fruits = {\"apple\", \"banana\", \"orange\"}\nprint(\"apple\" in fruits)\nprint(\"grape\" in fruits)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                },
                {
                    "type": "text",
                    "content": "`\"apple\"` is in the set (returns `True`), but `\"grape\"` is not (returns `False`)."
                }
            ]
        },
        {
            "id": "quick_check_in",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Check if `\"python\"` is in the set.",
