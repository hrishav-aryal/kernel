{
    "blocks": [
        {
            "id": "intro_sets",
            "elements": [
                {
                    "type": "heading",
                    "content": "Set Basics",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "A set is a collection that stores **unique values** - no duplicates allowed. Sets are useful when you want to keep track of distinct items."
                },
                {
                    "type": "text",
                    "content": "Unlike lists, sets are **unordered**, meaning items don't have a specific position or index."
                }
            ]
        },
        {
            "id": "creating_sets",
            "elements": [
                {
                    "type": "heading",
                    "content": "Creating Sets",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You create a set using **curly braces** `{}` with items separated by commas. Unlike dictionaries, sets don't have key-value pairs."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"green\", \"blue\"}\nprint(colors)",
                    "properties": {
                        "language": "python",
                        "output": "{'red', 'green', 'blue'}"
                    }
                },
                {
                    "type": "text",
                    "content": "This creates a set with three unique colors."
                }
            ]
        },
        {
            "id": "unique_values",
            "elements": [
                {
                    "type": "text",
                    "content": "Sets automatically **remove duplicates**. If you try to create a set with duplicate values, only one copy is kept."
                },
                {
                    "type": "code",
                    "content": "numbers = {1, 2, 2, 3, 3, 3}\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "{1, 2, 3}"
                    }
                },
                {
                    "type": "text",
                    "content": "The duplicates were automatically removed, leaving only unique values."
                }
            ]
        },
        {
            "id": "quick_check_create",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Create a set called `fruits` with values `\"apple\"`, `\"banana\"`, and `\"orange\"`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "fruits = {1}",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "print(fruits)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "[\"apple\", \"banana\", \"orange\"]",
                            "{\"apple\", \"banana\", \"orange\"}",
                            "(\"apple\", \"banana\", \"orange\")"
                        ],
                        "solutions": {
                            "1": "{\"apple\", \"banana\", \"orange\"}"
                        },
                        "hint": "Use curly braces {} with items separated by commas.",
                        "correctFeedback": "Perfect! You created a set with curly braces.",
                        "incorrectFeedback": "Use curly braces {} to create a set.",
                        "explanation": "Sets use curly braces {} like dictionaries, but without key-value pairs.",
                        "output": "{'apple', 'banana', 'orange'}"
                    }
                }
            ]
        },
        {
            "id": "quick_check_duplicates",
            "elements": [
                {
