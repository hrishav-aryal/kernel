                        "correctFeedback": "Correct! Sets automatically remove duplicates, keeping only one \"python\".",
                        "incorrectFeedback": "Sets remove duplicates automatically.",
                        "explanation": "The duplicate \"python\" is removed, leaving only unique values."
                    }
                }
            ]
        },
        {
            "id": "no_indexing",
            "elements": [
                {
                    "type": "text",
                    "content": "**Important:** You cannot access set items by index because sets are **unordered**."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"green\", \"blue\"}\n# colors[0]  # This would cause an error",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "text",
                    "content": "Sets don't support indexing like lists or tuples do."
                }
            ]
        },
        {
            "id": "adding_items",
            "elements": [
                {
                    "type": "heading",
                    "content": "Adding Items",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Use the `add()` method to add a single item to a set."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"green\"}\nprint(f\"Before: {colors}\")\n\ncolors.add(\"blue\")\nprint(f\"After: {colors}\")",
                    "properties": {
                        "language": "python",
                        "output": "Before: {'red', 'green'}\nAfter: {'red', 'green', 'blue'}"
                    }
                },
                {
                    "type": "text",
                    "content": "The new item `\"blue\"` was added to the set."
                }
            ]
        },
        {
            "id": "adding_duplicate",
            "elements": [
                {
                    "type": "text",
                    "content": "If you try to add an item that already exists, nothing happens. The set stays the same."
                },
                {
                    "type": "code",
                    "content": "numbers = {1, 2, 3}\nnumbers.add(2)\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "{1, 2, 3}"
                    }
                },
                {
                    "type": "text",
                    "content": "Adding `2` again has no effect because it already exists in the set."
                }
            ]
        },
        {
            "id": "quick_check_add",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Add `\"dog\"` to the set.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "animals = {\"cat\", \"bird\"}",
                                "indent": 0
                            },
                            {
                                "code": "animals.{1}({2})",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(animals)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "\"dog\"",
                            "append",
                            "add"
                        ],
                        "solutions": {
                            "1": "add",
                            "2": "\"dog\""
                        },
                        "hint": "Use add() to add an item to a set.",
                        "correctFeedback": "Perfect! add() adds a new item to the set.",
                        "incorrectFeedback": "Use add(\"dog\") to add the item.",
                        "explanation": "Unlike lists that use append(), sets use add() to add items.",
                        "output": "{'cat', 'bird', 'dog'}"
                    }
                }
            ]
        },
        {
            "id": "removing_items",
            "elements": [
                {
                    "type": "heading",
                    "content": "Removing Items",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Use the `remove()` method to delete an item from a set."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"green\", \"blue\"}\ncolors.remove(\"green\")\nprint(colors)",
                    "properties": {
                        "language": "python",
                        "output": "{'red', 'blue'}"
                    }
                },
                {
                    "type": "text",
                    "content": "The item `\"green\"` was removed from the set."
                }
            ]
        },
        {
            "id": "remove_error",
            "elements": [
                {
                    "type": "text",
                    "content": "**Be careful!** If you try to remove an item that doesn't exist, `remove()` causes an error."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"blue\"}\ncolors.remove(\"green\")",
                    "properties": {
                        "language": "python",
                        "output": "Error: KeyError: 'green'"
                    }
                },
                {
                    "type": "text",
                    "content": "Since `\"green\"` is not in the set, trying to remove it causes an error."
                }
            ]
        },
        {
            "id": "discard_method",
            "elements": [
                {
                    "type": "text",
                    "content": "To safely remove items, use `discard()`. It won't cause an error if the item doesn't exist."
                },
                {
                    "type": "code",
                    "content": "colors = {\"red\", \"blue\"}\ncolors.discard(\"green\")\nprint(colors)",
                    "properties": {
                        "language": "python",
                        "output": "{'red', 'blue'}"
                    }
                },
                {
                    "type": "text",
                    "content": "`discard()` safely handled the missing item without causing an error."
                }
            ]
        },
        {
            "id": "quick_check_remove",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Remove `2` from the set.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "numbers = {1, 2, 3, 4}",
                                "indent": 0
                            },
                            {
