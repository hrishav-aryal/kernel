        },
        {
            "id": "which_method_to_use",
            "elements": [
                {
                    "type": "text",
                    "content": "**Which method should you use?**"
                },
                {
                    "type": "text",
                    "content": "Use **keys** (default loop) when you only need keys. Use **values()** when you only need values. Use **items()** when you need both keys and values."
                }
            ]
        },
        {
            "id": "quick_check_which_method",
            "elements": [
                {
                    "type": "text",
                    "content": "Which method would you use to calculate the total of all values?"
                },
                {
                    "type": "mcq",
                    "content": "",
