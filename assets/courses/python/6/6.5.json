            ]
        },
        {
            "id": "quick_check_access_values",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Loop through keys and print each key with its value.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "ages = {\"Alice\": 25, \"Bob\": 30}",
                                "indent": 0
                            },
                            {
                                "code": "for name in ages:",
                                "indent": 0
                            },
                            {
                                "code": "    print(name)",
                                "indent": 0
                            },
                            {
                                "code": "    print(ages[{1}])",
                                "indent": 0,
                                "blank": "1"
                            }
                        ],
                        "options": [
                            "\"name\"",
                            "name",
                            "key"
                        ],
                        "solutions": {
                            "1": "name"
                        },
                        "hint": "Use the key variable name to access the value.",
                        "correctFeedback": "Perfect! You used the key to access its value.",
                        "incorrectFeedback": "Use ages[name] to get the value for each key.",
                        "explanation": "The loop variable (name) is the key, which you use to access values.",
                        "output": "Alice: 25\nBob: 30"
                    }
                }
            ]
        },
        {
            "id": "looping_values",
            "elements": [
                {
                    "type": "heading",
                    "content": "Looping Through Values",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Use the `values()` method to loop through just the **values**."
                },
                {
                    "type": "code",
                    "content": "scores = {\n    \"math\": 90,\n    \"english\": 85,\n    \"science\": 88\n}\n\nfor score in scores.values():\n    print(score)",
                    "properties": {
                        "language": "python",
                        "output": "90\n85\n88"
                    }
                },
                {
                    "type": "text",
                    "content": "The loop gives you only the values, not the keys."
                }
            ]
        },
        {
            "id": "values_practical",
            "elements": [
                {
                    "type": "text",
                    "content": "This is useful when you only care about the values, like calculating a total."
                },
                {
                    "type": "code",
                    "content": "prices = {\n    \"apple\": 2.50,\n    \"banana\": 1.50,\n    \"orange\": 3.00\n}\ntotal = 0\n\nfor price in prices.values():\n    total = total + price\n\nprint(f\"Total: ${total}\")",
                    "properties": {
                        "language": "python",
                        "output": "Total: $7.0"
                    }
                },
                {
                    "type": "text",
                    "content": "We summed all prices without needing the item names."
                }
            ]
        },
        {
            "id": "quick_check_values",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Loop through the values and print each one.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "inventory = {\"apples\": 50, \"oranges\": 30}",
                                "indent": 0
                            },
                            {
                                "code": "for quantity in inventory.{1}():",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "    print(quantity)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "keys",
                            "items",
                            "values"
                        ],
                        "solutions": {
                            "1": "values"
                        },
                        "hint": "Use values() to loop through only the values.",
                        "correctFeedback": "Perfect! values() gives you just the values.",
                        "incorrectFeedback": "Use values() to loop through dictionary values.",
                        "explanation": "The values() method returns only the values, not the keys.",
                        "output": "50\n30"
                    }
                }
            ]
        },
        {
            "id": "looping_items",
            "elements": [
                {
                    "type": "heading",
                    "content": "Looping Through Key-Value Pairs",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Use the `items()` method to loop through both **keys and values** at the same time. In this case, the `for` loop will take two variables, one for the key and one for the value."
                },
                {
                    "type": "code",
                    "content": "student = {\n    \"name\": \"Alice\",\n    \"age\": 20,\n    \"grade\": \"A\"\n}\n\nfor key, value in student.items():\n    print(f\"{key}: {value}\")",
                    "properties": {
                        "language": "python",
                        "output": "name: Alice\nage: 20\ngrade: A"
                    }
                },
                {
                    "type": "text",
                    "content": "The loop unpacks each key-value pair into two variables: `key` and `value`."
                }
            ]
        },
        {
            "id": "items_with_meaningful_names",
            "elements": [
                {
                    "type": "text",
                    "content": "You can use meaningful variable names instead of `key` and `value`."
                },
                {
                    "type": "code",
                    "content": "phone_book = {\n    \"Alice\": \"555-1234\",\n    \"Bob\": \"555-5678\"\n}\n\nfor name, number in phone_book.items():\n    print(f\"{name}'s number is {number}\")",
                    "properties": {
                        "language": "python",
                        "output": "Alice's number is 555-1234\nBob's number is 555-5678"
                    }
                },
                {
                    "type": "text",
                    "content": "Using `name` and `number` makes the code more readable."
                }
            ]
        },
        {
            "id": "quick_check_items",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Loop through key-value pairs and print them.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "colors = {\"r\": 255, \"g\": 128, \"b\": 0}",
                                "indent": 0
                            },
                            {
                                "code": "for color, value in colors.{1}():",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "    print(f\"{color}: {value}\")",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "values",
                            "items",
                            "pairs"
                        ],
                        "solutions": {
                            "1": "items"
                        },
                        "hint": "Use items() to loop through both keys and values.",
                        "correctFeedback": "Perfect! items() gives you both keys and values.",
                        "incorrectFeedback": "Use items() to loop through key-value pairs.",
                        "explanation": "items() returns pairs that can be unpacked into two variables.",
                        "output": "r: 255\ng: 128\nb: 0"
                    }
                }
            ]
        },
        {
