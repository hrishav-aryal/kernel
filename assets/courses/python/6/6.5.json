                        "question": "",
                        "options": [
                            "items()",
                            "keys()",
                            "values()"
                        ],
                        "correctAnswerIndex": 2,
                        "correctFeedback": "Correct! values() gives you just the values to sum.",
                        "incorrectFeedback": "Use values() when you only need the values, not the keys.",
                        "explanation": "When you only need values (not keys), use values() for simpler code."
                    }
                }
            ]
        },
