        {
            "id": "difference_operation",
            "elements": [
                {
                    "type": "heading",
                    "content": "Difference - Items in One Set Only",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `difference()` method finds items that are in the first set but **not** in the second set."
                },
                {
                    "type": "code",
                    "content": "set1 = {1, 2, 3, 4}\nset2 = {3, 4, 5, 6}\nresult = set1.difference(set2)\nprint(result)",
                    "properties": {
                        "language": "python",
                        "output": "{1, 2}"
                    }
                },
                {
                    "type": "text",
                    "content": "Items `1` and `2` are in `set1` but not in `set2`."
                }
            ]
        },
        {
            "id": "difference_operator",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also use the `-` operator for difference."
                },
                {
                    "type": "code",
                    "content": "all_students = {\"Alice\", \"Bob\", \"Charlie\"}\npresent = {\"Alice\", \"Bob\"}\nabsent = all_students - present\nprint(absent)",
                    "properties": {
                        "language": "python",
                        "output": "{'Charlie'}"
                    }
                },
                {
                    "type": "text",
                    "content": "Charlie is in `all_students` but not in `present`, so Charlie is absent."
                }
            ]
        },
