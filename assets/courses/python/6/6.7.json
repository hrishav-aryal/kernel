    "blocks": [
        {
            "id": "intro_operations",
            "elements": [
                {
                    "type": "heading",
                    "content": "Set Operations",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Sets have powerful operations that let you combine sets, find common items, or find differences between sets."
                },
                {
                    "type": "text",
                    "content": "These operations are useful for comparing groups, finding overlaps, or combining collections."
                }
            ]
        },
        {
            "id": "union_operation",
            "elements": [
                {
                    "type": "heading",
                    "content": "Union - Combining Sets",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `union()` method combines two sets, giving you **all unique items** from both sets."
                },
                {
                    "type": "code",
                    "content": "set1 = {1, 2, 3}\nset2 = {3, 4, 5}\nresult = set1.union(set2)\nprint(result)",
                    "properties": {
                        "language": "python",
                        "output": "{1, 2, 3, 4, 5}"
                    }
                },
                {
                    "type": "text",
                    "content": "The union contains all items from both sets. Note that `3` appears only once, even though it's in both sets."
                }
            ]
        },
        {
            "id": "union_operator",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also use the `|` operator for union. It works the same way as `union()`."
                },
                {
                    "type": "code",
                    "content": "fruits1 = {\"apple\", \"banana\"}\nfruits2 = {\"banana\", \"orange\"}\nall_fruits = fruits1 | fruits2\nprint(all_fruits)",
                    "properties": {
                        "language": "python",
                        "output": "{'apple', 'banana', 'orange'}"
                    }
                },
                {
                    "type": "text",
                    "content": "The `|` operator combines both sets, keeping only unique items."
                }
            ]
        },
        {
