        {
            "id": "subset_superset",
            "elements": [
                {
                    "type": "heading",
                    "content": "Checking Subsets",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can check if one set is a **subset** of another using `issubset()`. A subset means all items in one set are also in the other set."
                },
                {
                    "type": "code",
                    "content": "small = {1, 2}\nlarge = {1, 2, 3, 4}\nprint(small.issubset(large))",
                    "properties": {
                        "language": "python",
                        "output": "True"
                    }
                },
                {
                    "type": "text",
                    "content": "All items in `small` are in `large`, so `small` is a subset of `large`."
                }
            ]
        },
