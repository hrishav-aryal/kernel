        {
            "id": "intersection_operation",
            "elements": [
                {
                    "type": "heading",
                    "content": "Intersection - Common Items",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `intersection()` method finds items that exist in **both** sets."
                },
                {
                    "type": "code",
                    "content": "set1 = {1, 2, 3, 4}\nset2 = {3, 4, 5, 6}\ncommon = set1.intersection(set2)\nprint(common)",
                    "properties": {
                        "language": "python",
                        "output": "{3, 4}"
                    }
                },
                {
                    "type": "text",
                    "content": "Only `3` and `4` appear in both sets, so those are the common items."
                }
            ]
        },
        {
            "id": "intersection_operator",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also use the `&` operator for intersection."
                },
                {
                    "type": "code",
                    "content": "group1 = {\"Alice\", \"Bob\", \"Charlie\"}\ngroup2 = {\"Bob\", \"Charlie\", \"David\"}\nboth = group1 & group2\nprint(both)",
                    "properties": {
                        "language": "python",
                        "output": "{'Bob', 'Charlie'}"
                    }
                },
                {
                    "type": "text",
                    "content": "Bob and Charlie are in both groups, so they're in the intersection."
                }
            ]
        },
        {
