        {
            "id": "looping_tuples",
            "elements": [
                {
                    "type": "heading",
                    "content": "Looping Through Tuples",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can loop through tuples just like lists using a `for` loop."
                },
                {
                    "type": "code",
                    "content": "colors = (\"red\", \"green\", \"blue\")\nfor color in colors:\n    print(color)",
                    "properties": {
                        "language": "python",
                        "output": "red\ngreen\nblue"
                    }
                },
                {
                    "type": "text",
                    "content": "The loop goes through each item in the tuple."
                }
            ]
        },
        {
            "id": "quick_check_loop",
            "elements": [
