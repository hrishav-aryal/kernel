        {
            "id": "tuple_methods",
            "elements": [
                {
                    "type": "heading",
                    "content": "Tuple Methods",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Tuples have two useful methods: `count()` and `index()`."
                },
                {
                    "type": "text",
                    "content": "**count()** tells you how many times a value appears."
                },
                {
                    "type": "code",
                    "content": "numbers = (1, 2, 3, 2, 4, 2)\ncount = numbers.count(2)\nprint(f\"2 appears {count} times\")",
                    "properties": {
                        "language": "python",
                        "output": "2 appears 3 times"
                    }
                },
                {
                    "type": "text",
                    "content": "The number `2` appears 3 times in the tuple."
                }
            ]
        },
        {
            "id": "index_method",
            "elements": [
                {
                    "type": "text",
                    "content": "**index()** finds the position of the first occurrence of a value."
                },
                {
                    "type": "code",
                    "content": "colors = (\"red\", \"green\", \"green\")\nposition = colors.index(\"green\")\nprint(f\"First green index: {position}\")",
                    "properties": {
                        "language": "python",
                        "output": "First green index: 1"
                    }
                },
                {
                    "type": "text",
                    "content": "The first `\"green\"` is at index `1`."
                }
            ]
        },
        {
            "id": "quick_check_count",
