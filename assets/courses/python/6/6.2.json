        {
            "id": "when_to_use_tuples",
            "elements": [
                {
                    "type": "text",
                    "content": "**When should you use tuples?**"
                },
                {
                    "type": "text",
                    "content": "Use tuples when you have data that should **not change**: coordinates `(x, y)`, RGB colors `(r, g, b)`, date/time `(year, month, day)`, or database records."
                },
                {
                    "type": "text",
                    "content": "Tuples are also faster and use less memory than lists, so use them when you don't need to modify the data."
                }
            ]
        },
