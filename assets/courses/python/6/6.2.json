                    }
                }
            ]
        },
        {
            "id": "checking_membership",
            "elements": [
                {
                    "type": "text",
                    "content": "You can use the `in` operator to check if a value exists in a tuple."
                },
                {
                    "type": "code",
                    "content": "rgb = (255, 0, 0)\nprint(255 in rgb)\nprint(100 in rgb)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                },
                {
                    "type": "text",
                    "content": "`255` is in the tuple (returns `True`), but `100` is not (returns `False`)."
                }
            ]
        },
        {
