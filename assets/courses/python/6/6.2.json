        {
            "id": "combining_tuples",
            "elements": [
                {
                    "type": "text",
                    "content": "You can combine tuples using the `+` operator, just like lists."
                },
                {
                    "type": "code",
                    "content": "first = (1, 2, 3)\nsecond = (4, 5, 6)\ncombined = first + second\nprint(combined)",
                    "properties": {
                        "language": "python",
                        "output": "(1, 2, 3, 4, 5, 6)"
                    }
                },
                {
                    "type": "text",
                    "content": "The `+` operator creates a new tuple with items from both tuples."
                }
            ]
        },
