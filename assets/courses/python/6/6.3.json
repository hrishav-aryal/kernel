                        },
                        "hint": "Use \"price\" in product to check if the key exists.",
                        "correctFeedback": "Perfect! The in operator checks if a key exists in a dictionary.",
                        "incorrectFeedback": "Use \"price\" in product to check for the key.",
                        "explanation": "Checking with in prevents errors when accessing dictionary keys.",
                        "output": "999"
                    }
                }
            ]
        },
        {
            "id": "dictionary_length",
            "elements": [
                {
                    "type": "text",
                    "content": "Use `len()` to find how many key-value pairs are in a dictionary."
                },
                {
                    "type": "code",
                    "content": "student = {\"name\": \"Alice\", \"age\": 20, \"grade\": \"A\"}\nprint(len(student))",
                    "properties": {
                        "language": "python",
                        "output": "3"
                    }
                },
                {
                    "type": "text",
                    "content": "The dictionary has 3 key-value pairs."
                }
            ]
        },
