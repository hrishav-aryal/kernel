                        "output": "cat"
                    }
                }
            ]
        },
        {
            "id": "quick_check_variable_creation",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Fill in the **value** for the variable `greeting`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "greeting = {1}",
                                "indent": 0,
                                "blank": "1"
                            },
                            {
                                "code": "print(greeting)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "\"Good morning!\""
                        ],
                        "solutions": {
                            "1": "\"Good morning!\""
                        },
                        "hint": "Use quotes around the text value",
                        "correctFeedback": "Perfect! You assigned the correct value with quotes.",
                        "incorrectFeedback": "Use quotes around the text: \"Good morning!\"",
                        "explanation": "Text values must be enclosed in quotes.",
                        "output": "Good morning!"
                    }
                }
            ]
        },
        {
            "id": "using_variables",
            "elements": [
                {
                    "type": "heading",
                    "content": "Using Variables",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Once you create a variable, you can use it anywhere in your program. This makes your code more flexible and easier to change."
                },
                {
                    "type": "code",
                    "content": "# Create a variable\nuser_name = \"Bob\"\n\n# Use it multiple times\nprint(\"Hello, \" + user_name)\nprint(\"Welcome, \" + user_name)\nprint(user_name + \" is learning Python!\")",
                    "properties": {
                        "language": "python",
                        "caption": "Reusing variables",
                        "output": "Hello, Bob\nWelcome, Bob\nBob is learning Python!"
                    }
                }
            ]
        },
        {
            "id": "quick_check_using_variables_practice",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Use the `name` variable to create a greeting message.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "name = \"Sarah\"",
                                "indent": 0
                            },
                            {
                                "code": "print(\"Hello, \" + {1})",
                                "indent": 0,
                                "blank": "1"
                            }
                        ],
                        "options": [
                            "name"
                        ],
                        "solutions": {
                            "1": "name"
                        },
                        "hint": "Use the variable name inside the print statement",
                        "correctFeedback": "Perfect! You used the variable in your message.",
                        "incorrectFeedback": "Use the variable name 'name' in the print statement",
                        "explanation": "You can use variables inside print statements to create dynamic messages.",
                        "output": "Hello, Sarah"
                    }
                }
            ]
        },
        {
            "id": "changing_variables",
            "elements": [
                {
                    "type": "heading",
                    "content": "Changing Variables",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can change the value of a variable anytime by assigning a new value to it."
                },
                {
                    "type": "code",
                    "content": "# Create a variable\nscore = 10\nprint(\"Initial score:\", score)\n\n# Change the variable\nscore = 15\nprint(\"Updated score:\", score)\n\n# Change it again\nscore = 20\nprint(\"Final score:\", score)",
                    "properties": {
                        "language": "python",
                        "caption": "Changing variable values",
                        "output": "Initial score: 10\nUpdated score: 15\nFinal score: 20"
                    }
                }
            ]
        },
        {
            "id": "quick_check_simple_change",
            "elements": [
                {
                    "type": "text",
                    "content": "What will this code print?"
                },
                {
                    "type": "code",
                    "content": "color = \"red\"\ncolor = \"blue\"\nprint(color)",
                    "properties": {
                        "language": "python",
                        "caption": "What will this code print?",
                        "output": "blue"
                    }
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "red",
                            "blue",
                            "red blue"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! The variable **color** gets updated to **\"blue\"**.",
                        "incorrectFeedback": "The variable gets updated to the new value **\"blue\"**.",
                        "explanation": "When you assign a new value to a variable, it replaces the old value."
                    }
                }
            ]
        },
        {
