        {
            "id": "common_mistakes_variables",
            "elements": [
                {
                    "type": "heading",
                    "content": "Common Mistakes",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "When working with variables, watch out for these common mistakes:"
                }
            ]
        },
        {
            "id": "forgetting_equals",
            "elements": [
                {
                    "type": "text",
                    "content": "**Forgetting the equals sign** when creating variables"
                },
                {
                    "type": "code",
                    "content": "name \"Alice\"",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "text",
                    "content": "This code is **missing the equals sign**. Python needs **=** to assign values to variables."
                },
                {
                    "type": "code",
                    "content": "# Correct - use equals sign\nname = \"Alice\"",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "using_undefined_variable",
            "elements": [
                {
                    "type": "text",
                    "content": "**Using a variable before creating it**"
                },
                {
                    "type": "code",
                    "content": "print(name)\nname = \"Alice\"",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "text",
                    "content": "This code tries to use `name` before creating it. Python doesn't know what `name` is yet."
                },
                {
                    "type": "code",
                    "content": "# Correct - create variable first\nname = \"Alice\"\nprint(name)",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "quick_check_mistakes",
