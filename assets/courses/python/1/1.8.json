            "id": "string_access",
            "elements": [
                {
                    "type": "heading",
                    "content": "Accessing Characters",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "We can access individual characters in a string using square brackets `[]` with an index number."
                },
                {
                    "type": "code",
                    "content": "word = \"Hello\"\nprint(word[0])",
                    "properties": {
                        "language": "python",
                        "output": "H"
                    }
                }
            ]
        },
        {
            "id": "string_indexing_explanation",
            "elements": [
                {
                    "type": "text",
                    "content": "String indexing starts at **0**, not 1. So the first character is at index 0, second at index 1, and so on."
                },
                {
                    "type": "code",
                    "content": "# Index:  0 1 2 3 4\n# Word:   H e l l o",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
