                                "blank": "1,2"
                            }
                        ],
                        "options": [
                            "type",
                            "is_ready"
                        ],
                        "solutions": {
                            "1": "type",
                            "2": "is_ready"
                        },
                        "hint": "Use type() with the variable name",
                        "correctFeedback": "Excellent! You checked the data type of the boolean variable.",
                        "incorrectFeedback": "Use type() with the variable name",
                        "explanation": "Use type(variable_name) to check the data type.",
                        "output": "<class 'bool'>"
                    }
                }
            ]
        },
