{
    "blocks": [
        {
            "id": "intro_type_conversion",
            "elements": [
                {
                    "type": "heading",
                    "content": "Type Conversion",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Sometimes you need to change a variable from one data type to another. This is called **type conversion** or **type casting**."
                }
            ]
        },
        {
            "id": "what_is_type_conversion",
            "elements": [
                {
                    "type": "heading",
                    "content": "What is Type Conversion?",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Type conversion allows you to convert data from one type to another. Python provides built-in functions to do this safely."
                }
            ]
        },
        {
            "id": "conversion_functions",
            "elements": [
                {
                    "type": "text",
                    "content": "Python has three main conversion functions:"
                },
                {
                    "type": "code",
                    "content": "# Convert to string\nstr(25)\n\n# Convert to integer\nint(\"25\")\n\n# Convert to float\nfloat(\"25.5\")",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "str_function",
            "elements": [
                {
                    "type": "text",
                    "content": "`str()` converts any value to a string."
                },
                {
                    "type": "code",
                    "content": "age = 25\nage_string = str(age)",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "int_function",
            "elements": [
                {
                    "type": "text",
                    "content": "`int()` converts a string or float to an integer."
                },
                {
                    "type": "code",
                    "content": "age_string = \"25\"\nage = int(age_string)",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "float_function",
            "elements": [
                {
                    "type": "text",
                    "content": "`float()` converts a string or integer to a float."
                },
                {
                    "type": "code",
                    "content": "price_string = \"19.99\"\nprice = float(price_string)",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "quick_check_convert_to_string",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Convert the number `25` to a string.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "number = 25",
                                "indent": 0
                            },
                            {
                                "code": "text = {1}(number)",
                                "indent": 0,
                                "blank": "1"
                            }
                        ],
                        "options": [
                            "str"
                        ],
                        "solutions": {
                            "1": "str"
