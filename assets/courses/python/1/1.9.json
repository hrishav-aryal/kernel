        {
            "id": "assignment_operators",
            "elements": [
                {
                    "type": "heading",
                    "content": "Assignment Operators",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Assignment operators are shortcuts for doing math and assigning the result back to the same variable. So instead of writing `x = x + 5`, you can write `x += 5`."
                },
                {
                    "type": "code",
                    "content": "x = x + 5\n\nx += 5",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "assignment_operators_examples",
            "elements": [
                {
                    "type": "text",
                    "content": "Here are the common assignment operators:"
                },
                {
                    "type": "code",
                    "content": "x = 10\nx += 3  # x = x + 3\nx -= 2  # x = x - 2\nx *= 4  # x = x * 4\nx /= 2  # x = x / 2\nprint(x)",
                    "properties": {
                        "language": "python",
                        "output": "22.0"
                    }
                }
            ]
        },
