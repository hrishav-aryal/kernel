        {
            "id": "order_of_operations",
            "elements": [
                {
                    "type": "text",
                    "content": "Python follows the same order of operations as math: multiplication and division happen before addition and subtraction."
                },
                {
                    "type": "code",
                    "content": "result = 2 + 3 * 4\nprint(result)",
                    "properties": {
                        "language": "python",
                        "output": "14"
                    }
                }
            ]
        },
