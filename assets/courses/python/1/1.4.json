        {
            "id": "assignment_operator",
            "elements": [
                {
                    "type": "heading",
                    "content": "The Assignment Operator",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You might have already noticed that the `=` sign is used to assign a value to a variable."
                },
                {
                    "type": "code",
                    "content": "name = \"Alice\"\nage = 25\ncity = \"New York\"",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "multiple_assignments",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also assign the same value to **multiple variables** at once."
                },
                {
                    "type": "code",
                    "content": "x = y = z = 0",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
        {
            "id": "quick_check_assignment",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Use the assignment operator to create a variable called `color`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "color {1} \"blue\"",
                                "indent": 0,
                                "blank": "1"
