        {
            "id": "good_vs_bad_names",
            "elements": [
                {
                    "type": "text",
                    "content": "Another important habit is to use **descriptive** variable names that help you understand what the variable stores."
                },
                {
                    "type": "code",
                    "content": "student_name = \"Alice\"\nstudent_age = 20",
                    "properties": {
                        "language": "python"
                    }
                }
            ]
        },
