{
    "blocks": [
        {
            "id": "intro_removing_items",
            "elements": [
                {
                    "type": "heading",
                    "content": "Removing from Lists",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Just like you can add items to a list, you can also remove them. Python gives you several ways to remove items depending on what you know about the item."
                },
                {
                    "type": "text",
                    "content": "You can remove by value, by position, or clear the entire list."
                }
            ]
        },
        {
            "id": "remove_by_value",
            "elements": [
                {
                    "type": "heading",
                    "content": "Remove by Value",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `remove()` method removes the **first occurrence** of a specific value from the list."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits)\n\nfruits.remove(\"banana\")\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana', 'orange']\n['apple', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "`remove(\"banana\")` found `\"banana\"` in the list and removed it."
                }
            ]
        },
        {
            "id": "remove_first_occurrence",
            "elements": [
                {
                    "type": "text",
                    "content": "If the same value appears multiple times, `remove()` only removes the **first one**."
                },
                {
                    "type": "code",
                    "content": "numbers = [1, 2, 3, 2, 4]\nnumbers.remove(2)\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 3, 2, 4]"
                    }
                },
                {
                    "type": "text",
                    "content": "The first `2` was removed, but the second `2` is still in the list."
                }
            ]
        },
        {
            "id": "remove_error",
            "elements": [
                {
                    "type": "text",
                    "content": "**Be careful!** If the value doesn't exist in the list, you'll get an error."
                },
                {
                    "type": "code",
                    "content": "colors = [\"red\", \"green\"]\ncolors.remove(\"blue\")",
                    "properties": {
                        "language": "python",
                        "output": "Error: 'blue' is not in list"
                    }
                },
                {
                    "type": "text",
                    "content": "Since `\"blue\"` is not in the list, trying to remove it causes an error."
                }
            ]
        },
