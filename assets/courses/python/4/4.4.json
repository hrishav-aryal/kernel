        {
            "id": "del_statement",
            "elements": [
                {
                    "type": "heading",
                    "content": "Remove by Index with del",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `del` statement removes an item at a specific index, but unlike `pop()`, it doesn't return the item."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\ndel fruits[1]\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "`del fruits[1]` removed the item at index `1` without returning it."
                }
            ]
        },
        {
            "id": "del_vs_pop",
            "elements": [
                {
                    "type": "text",
                    "content": "**When to use del vs pop()?**"
                },
                {
                    "type": "text",
                    "content": "Use `pop()` when you need the removed value. Use `del` when you just want to delete without using the value."
                }
            ]
        },
        {
            "id": "quick_check_del",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Delete the item at index `2` using del.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "colors = [\"red\", \"green\", \"blue\"]",
                                "indent": 0
                            },
                            {
                                "code": "{1} colors[{2}]",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(colors)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "del",
                            "2",
                            "remove"
                        ],
                        "solutions": {
                            "1": "del",
                            "2": "2"
                        },
                        "hint": "Use del list[index] to remove by index.",
                        "correctFeedback": "Perfect! del colors[2] removed the item at index 2.",
                        "incorrectFeedback": "Use del colors[2] to remove the item at index 2.",
                        "explanation": "del followed by the list[index] removes the item at that index.",
                        "output": "['red', 'green']"
                    }
                }
            ]
        },
        {
            "id": "quick_check_methods_comparison",
            "elements": [
                {
                    "type": "text",
