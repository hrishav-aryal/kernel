                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "remove()",
                            "pop()",
                            "del"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! pop() removes the item and returns it so you can use it.",
                        "incorrectFeedback": "pop() is the only method that returns the removed value.",
                        "explanation": "pop() removes and returns the value, while remove() and del just remove without returning."
                    }
                }
            ]
        },
        {
            "id": "clear_method",
            "elements": [
                {
                    "type": "heading",
                    "content": "Clear All Items",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `clear()` method removes **all** items from the list, leaving it empty."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nfruits.clear()\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "[]"
                    }
                },
                {
                    "type": "text",
                    "content": "`clear()` removed all items, leaving an empty list."
                }
            ]
        },
