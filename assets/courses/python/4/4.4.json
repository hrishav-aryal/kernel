        },
        {
            "id": "pop_method",
            "elements": [
                {
                    "type": "heading",
                    "content": "Remove by Index with pop()",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `pop()` method removes an item at a specific index and **returns** that item."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nremoved = fruits.pop(1)\nprint(f\"Removed: {removed}\")\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "Removed: banana\n['apple', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "`pop(1)` removed the item at index `1` (`\"banana\"`) and returned it."
                }
            ]
        },
        {
            "id": "pop_without_index",
            "elements": [
                {
                    "type": "text",
                    "content": "If you don't provide an index, `pop()` removes and returns the **last item**."
                },
                {
                    "type": "code",
                    "content": "numbers = [10, 20, 30]\nlast = numbers.pop()\nprint(f\"Last: {last}\")\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "Last: 30\n[10, 20]"
                    }
                },
                {
                    "type": "text",
                    "content": "`pop()` with no index removes the last item from the list."
                }
            ]
        },
