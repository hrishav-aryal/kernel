    "blocks": [
        {
            "id": "intro_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "List Basics",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "A list is a collection of items that are ordered and changeable. You can store multiple values in a single variable using a list."
                },
                {
                    "type": "text",
                    "content": "Lists are very useful when you need to work with multiple pieces of data together, like a list of names, numbers, or any other values."
                }
            ]
        },
        {
            "id": "creating_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Creating Lists",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You create a list by putting items inside square brackets `[]`, separated by commas."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "This creates a list called `fruits` with three items: `\"apple\"`, `\"banana\"`, and `\"orange\"`."
                }
            ]
        },
        {
            "id": "list_with_numbers",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also create lists with numbers."
                },
                {
                    "type": "code",
                    "content": "numbers = [1, 2, 3, 4, 5]\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 2, 3, 4, 5]"
                    }
                },
                {
                    "type": "text",
                    "content": "This creates a list of numbers from 1 to 5."
                }
            ]
        },
        {
            "id": "list_with_mixed_types",
            "elements": [
                {
                    "type": "text",
                    "content": "Lists can contain different types of data in the same list."
                },
                {
                    "type": "code",
                    "content": "mixed = [1, \"hello\", 3.14, True]\nprint(mixed)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 'hello', 3.14, True]"
                    }
                },
                {
                    "type": "text",
                    "content": "This list contains a number, a string, a decimal number, and a boolean value."
                }
            ]
        },
        {
            "id": "empty_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Empty Lists",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can also create an empty list (a list with no items) using empty square brackets `[]`."
                },
                {
                    "type": "code",
                    "content": "empty_list = []\nprint(empty_list)",
                    "properties": {
                        "language": "python",
                        "output": "Empty list: []\nLength: 0"
                    }
                },
                {
                    "type": "text",
                    "content": "Empty lists are useful when you want to start with no items and add them later."
                }
            ]
        },
