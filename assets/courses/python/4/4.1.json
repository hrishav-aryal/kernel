        {
            "id": "list_length",
            "elements": [
                {
                    "type": "heading",
                    "content": "List Length",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can find out how many items are in a list using the `len()` function."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint({len(fruits))",
                    "properties": {
                        "language": "python",
                        "output": "3"
                    }
                },
                {
                    "type": "text",
                    "content": "The `len()` function tells you the total number of items in the list."
                }
            ]
        },
