                }
            ]
        },
        {
            "id": "slice_from_start",
            "elements": [
                {
                    "type": "heading",
                    "content": "Slicing from the Start",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "If you leave out the start index, Python starts from the beginning of the list."
                },
                {
                    "type": "code",
                    "content": "letters = [\"a\", \"b\", \"c\", \"d\", \"e\"]\nfirst_three = letters[:3]\nprint(first_three)",
                    "properties": {
                        "language": "python",
                        "output": "['a', 'b', 'c']"
                    }
                },
                {
                    "type": "text",
                    "content": "`[:3]` gets items from the start up to (not including) index `3`."
                }
            ]
        },
        {
            "id": "slice_to_end",
            "elements": [
                {
                    "type": "heading",
                    "content": "Slicing to the End",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "If you leave out the stop index, Python goes all the way to the end of the list."
                },
                {
                    "type": "code",
                    "content": "letters = [\"a\", \"b\", \"c\", \"d\", \"e\"]\nlast_two = letters[2:]\nprint(last_two)",
                    "properties": {
                        "language": "python",
                        "output": "['c', 'd', 'e']"
                    }
                },
                {
                    "type": "text",
                    "content": "`[2:]` gets items from index `2` to the end of the list."
                }
            ]
        },
