        {
            "id": "repeating_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Repeating Lists",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can repeat a list multiple times using the `*` operator."
                },
                {
                    "type": "code",
                    "content": "pattern = [\"x\", \"o\"]\nrepeated = pattern * 3\nprint(repeated)",
                    "properties": {
                        "language": "python",
                        "output": "['x', 'o', 'x', 'o', 'x', 'o']"
                    }
                },
                {
                    "type": "text",
                    "content": "`pattern * 3` repeats the list 3 times."
                }
            ]
        },
        {
            "id": "repeating_practical",
            "elements": [
                {
                    "type": "text",
                    "content": "This is useful for creating lists with repeated values."
                },
                {
                    "type": "code",
                    "content": "zeros = [0] * 5\nprint(zeros)",
                    "properties": {
                        "language": "python",
                        "output": "[0, 0, 0, 0, 0]"
                    }
                },
                {
                    "type": "text",
                    "content": "`[0] * 5` creates a list with five zeros."
                }
            ]
        },
