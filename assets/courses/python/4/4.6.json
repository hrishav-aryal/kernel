        {
            "id": "combining_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Combining Lists",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can combine two or more lists using the `+` operator. This creates a new list with all items from both lists."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\"]\nveggies = [\"carrot\", \"broccoli\"]\nfood = fruits + veggies\nprint(food)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana', 'carrot', 'broccoli']"
                    }
                },
                {
                    "type": "text",
                    "content": "The `+` operator joined both lists into one new list."
                }
            ]
        },
        {
            "id": "combining_multiple",
            "elements": [
                {
                    "type": "text",
                    "content": "You can combine more than two lists at once."
                },
                {
                    "type": "code",
                    "content": "list1 = [1, 2]\nlist2 = [3, 4]\nlist3 = [5, 6]\ncombined = list1 + list2 + list3\nprint(combined)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 2, 3, 4, 5, 6]"
                    }
                },
                {
                    "type": "text",
                    "content": "All three lists are combined in order into one list."
                }
            ]
        },
