{
    "blocks": [
        {
            "id": "intro_slicing_combining",
            "elements": [
                {
                    "type": "heading",
                    "content": "Slicing & Combining Lists",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Sometimes you need just part of a list, not the whole thing. **Slicing** lets you get a portion of a list. You can also combine multiple lists together or repeat them."
                },
                {
                    "type": "text",
                    "content": "These operations let you work with lists in powerful ways."
                }
            ]
        },
        {
            "id": "basic_slicing",
            "elements": [
                {
                    "type": "heading",
                    "content": "List Slicing",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "Slicing uses the format `list[start:stop]` to get items from index `start` up to (but not including) index `stop`."
                },
                {
                    "type": "code",
                    "content": "letters = [\"a\", \"b\", \"c\", \"d\", \"e\"]\nsliced = letters[1:4]\nprint(sliced)",
                    "properties": {
                        "language": "python",
                        "output": "['b', 'c', 'd']"
                    }
                },
                {
                    "type": "text",
                    "content": "`letters[1:4]` gets items from index 1 up to (but not including) index 4, giving us indices `1, 2, and 3`."
                }
            ]
        },
        {
            "id": "slicing_visual",
            "elements": [
                {
                    "type": "text",
                    "content": "Think of slicing like selecting a range. If you have items at indices `0, 1, 2, 3, 4`, then `[1:4]` selects indices 1, 2, and 3."
                },
                {
                    "type": "code",
                    "content": "numbers = [10, 20, 30, 40, 50]\nprint(numbers[0:3])\nprint(numbers[2:5])",
                    "properties": {
                        "language": "python",
                        "output": "[10, 20, 30]\n[30, 40, 50]"
                    }
                },
                {
                    "type": "text",
                    "content": "`[0:3]` gets indices `0, 1, 2`. `[2:5]` gets indices `2, 3, 4`."
                }
            ]
        },
        {
            "id": "quick_check_basic_slice",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Get colors `\"red\"` and `\"green\"` from the list `colors`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "colors = [\"red\", \"green\", \"blue\"]",
                                "indent": 0
                            },
                            {
                                "code": "result = colors[{1}:{2}]",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(result)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "1",
                            "0",
                            "2"
                        ],
                        "solutions": {
                            "1": "0",
                            "2": "2"
                        },
                        "hint": "Use [0:2] to get items from index 0 up to (not including) index 2.",
                        "correctFeedback": "Perfect! [0:2] gets items at indices 0 and 1.",
                        "incorrectFeedback": "Use [0:2] to get indices 0 and 1.",
                        "explanation": "Slicing [0:2] starts at index 0 and stops before index 2, giving us indices 0 and 1.",
                        "output": "['red', 'green']"
                    }
                }
            ]
        },
