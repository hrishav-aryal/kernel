                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! [2:4] gets indices 2 and 3, which are 'c' and 'd'.",
                        "incorrectFeedback": "[2:4] gets indices 2 and 3 (stops before 4).",
