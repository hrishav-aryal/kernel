{
    "blocks": [
        {
            "id": "intro_modifying_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Modifying Lists",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "One of the most powerful features of lists is that you can change them after creating them. You can update existing items or add new items to the list."
                },
                {
                    "type": "text",
                    "content": "This makes lists very flexible for storing data that changes over time."
                }
            ]
        },
        {
            "id": "changing_items",
            "elements": [
                {
                    "type": "heading",
                    "content": "Changing Items",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can change any item in a list by accessing its index and assigning a new value using `=`."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits)\n\nfruits[1] = \"mango\"\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana', 'orange']\n['apple', 'mango', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "We changed the item at index `1` from `\"banana\"` to `\"mango\"`."
                }
            ]
        },
        {
            "id": "quick_check_changing",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Change the second item in the list to `50`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "numbers = [10, 20, 30]",
                                "indent": 0
                            },
                            {
                                "code": "numbers[{1}] = {2}",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(numbers)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "0",
                            "50",
                            "1"
                        ],
                        "solutions": {
                            "1": "1",
                            "2": "50"
                        },
                        "hint": "The second item is at index 1.",
                        "correctFeedback": "Perfect! You changed the second item (index 1) to 50.",
                        "incorrectFeedback": "The second item is at index 1. Use numbers[1] = 50.",
                        "explanation": "Index 1 is the second item in the list, so numbers[1] = 50 changes it.",
                        "output": "[10, 50, 30]"
                    }
                }
            ]
        },
        {
            "id": "quick_check_change_last",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Change the last item in the list to `\"dog\"`.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "animals = [\"cat\", \"bird\", \"fish\"]",
                                "indent": 0
                            },
                            {
                                "code": "animals[{1}] = {2}",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
