                    }
                }
            ]
        },
        {
            "id": "adding_with_append",
            "elements": [
                {
                    "type": "heading",
                    "content": "Adding Items with append()",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `append()` method adds a new item to the **end** of the list."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\"]\nprint(fruits)\n\nfruits.append(\"orange\")\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana']\n['apple', 'banana', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "`append()` added `\"orange\"` to the end of the list."
                }
            ]
        },
        {
            "id": "append_multiple",
            "elements": [
                {
                    "type": "text",
                    "content": "You can call `append()` multiple times to add multiple items."
                },
                {
                    "type": "code",
                    "content": "numbers = [1, 2, 3]\nnumbers.append(4)\nnumbers.append(5)\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 2, 3, 4, 5]"
                    }
                },
                {
                    "type": "text",
                    "content": "Each `append()` adds one item to the end of the list."
                }
            ]
        },
        {
            "id": "quick_check_append",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Add `\"blue\"` to the end of the list.",
                    "properties": {
                        "language": "python",
                        "lines": [
                            {
                                "code": "colors = [\"red\", \"green\"]",
                                "indent": 0
                            },
                            {
                                "code": "colors.{1}({2})",
                                "indent": 0,
                                "blank": "1,2"
                            },
                            {
                                "code": "print(colors)",
                                "indent": 0
                            }
                        ],
                        "options": [
                            "add",
                            "\"blue\"",
                            "append"
                        ],
                        "solutions": {
                            "1": "append",
                            "2": "\"blue\""
                        },
                        "hint": "Use append() to add items to the end of a list.",
                        "correctFeedback": "Perfect! append() added \"blue\" to the end of the list.",
                        "incorrectFeedback": "Use append() to add items to the end of a list.",
                        "explanation": "The append() method adds the item to the end of the list.",
                        "output": "['red', 'green', 'blue']"
                    }
                }
            ]
        },
        {
            "id": "quick_check_what_will_print_append",
            "elements": [
                {
                    "type": "text",
                    "content": "What will this code print?"
                },
                {
                    "type": "code",
                    "content": "scores = [85, 90]\nscores.append(95)\nprint(scores)",
                    "properties": {
                        "language": "python"
                    }
                },
                {
                    "type": "mcq",
                    "content": "",
                    "properties": {
                        "question": "",
                        "options": [
                            "[95, 85, 90]",
                            "[85, 90, 95]"
                        ],
                        "correctAnswerIndex": 1,
                        "correctFeedback": "Correct! append() adds 95 to the end of the list.",
                        "incorrectFeedback": "append() adds items to the end of the list, so 95 comes last.",
                        "explanation": "append() always adds items to the end, so 95 is added after 85 and 90."
                    }
                }
            ]
        },
        {
            "id": "adding_with_insert",
            "elements": [
                {
                    "type": "heading",
                    "content": "Adding Items with insert()",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `insert()` method adds a new item at a **specific position** in the list. You need to provide the index and the item."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"orange\"]\nfruits.insert(1, \"banana\")\nprint(fruits)",
                    "properties": {
                        "language": "python",
                        "output": "['apple', 'banana', 'orange']"
                    }
                },
                {
                    "type": "text",
                    "content": "`insert(1, \"banana\")` added `\"banana\"` at index `1`, pushing `\"orange\"` to index `2`."
                }
            ]
        },
        {
            "id": "insert_at_beginning",
            "elements": [
                {
                    "type": "text",
                    "content": "You can insert at the beginning of the list using index `0`."
                },
                {
                    "type": "code",
                    "content": "numbers = [2, 3, 4]\nnumbers.insert(0, 1)\nprint(numbers)",
                    "properties": {
                        "language": "python",
                        "output": "[1, 2, 3, 4]"
                    }
                },
                {
                    "type": "text",
                    "content": "`insert(0, 1)` added `1` at the beginning, shifting all other items to the right."
                }
            ]
        },
        {
            "id": "insert_vs_append",
            "elements": [
                {
                    "type": "text",
                    "content": "**When to use which?**"
                },
                {
                    "type": "text",
                    "content": "Use `append()` when you want to add to the end. Use `insert()` when you need to add at a specific position."
                }
            ]
        },
        {
            "id": "quick_check_insert",
            "elements": [
                {
                    "type": "code_fill",
                    "content": "Insert `\"yellow\"` at index `1`.",
