                        },
                        "hint": "Use insert(index, item) to add at a specific position.",
                        "correctFeedback": "Perfect! insert(1, \"yellow\") adds \"yellow\" at index 1.",
                        "incorrectFeedback": "Use insert(1, \"yellow\") to add at index 1.",
                        "explanation": "insert() takes the index first, then the item to insert.",
                        "output": "['red', 'yellow', 'green']"
                    }
                }
            ]
        },
