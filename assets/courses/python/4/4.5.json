        {
            "id": "loop_with_operations",
            "elements": [
                {
                    "type": "text",
                    "content": "You can perform operations on each item inside the loop."
                },
                {
                    "type": "code",
                    "content": "numbers = [1, 2, 3, 4]\nfor num in numbers:\n    doubled = num * 2\n    print(f\"{num} doubled is {doubled}\")",
                    "properties": {
                        "language": "python",
                        "output": "1 doubled is 2\n2 doubled is 4\n3 doubled is 6\n4 doubled is 8"
                    }
                },
                {
                    "type": "text",
                    "content": "For each number, we multiply it by 2 and print the result."
                }
            ]
        },
        {
            "id": "quick_check_loop_operations",
            "elements": [
