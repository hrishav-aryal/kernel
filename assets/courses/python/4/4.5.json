        {
            "id": "checking_membership",
            "elements": [
                {
                    "type": "heading",
                    "content": "Checking if Items Exist",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `in` operator checks if an item exists in a list. It returns `True` if the item is found, and `False` if it's not."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(\"apple\" in fruits)\nprint(\"grape\" in fruits)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                },
                {
                    "type": "text",
                    "content": "`\"apple\"` is in the list, so the first check returns `True`. `\"grape\"` is not in the list, so it returns `False`."
                }
            ]
        },
        {
            "id": "using_in_with_if",
            "elements": [
                {
                    "type": "text",
                    "content": "The `in` operator is commonly used with `if` statements to make decisions based on whether an item exists."
                },
                {
                    "type": "code",
                    "content": "shopping_list = [\"milk\", \"bread\", \"eggs\"]\nif \"milk\" in shopping_list:\n    print(\"Don't forget the milk!\")",
                    "properties": {
                        "language": "python",
                        "output": "Don't forget the milk!"
                    }
                },
                {
                    "type": "text",
                    "content": "Since `\"milk\"` is in the list, the message is printed."
                }
            ]
        },
        {
