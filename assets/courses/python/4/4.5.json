        {
            "id": "not_in_operator",
            "elements": [
                {
                    "type": "heading",
                    "content": "Checking if Items Don't Exist",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "The `not in` operator checks if an item is **not** in a list. It returns `True` if the item is not found."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\"]\nprint(\"grape\" not in fruits)\nprint(\"apple\" not in fruits)",
                    "properties": {
                        "language": "python",
                        "output": "True\nFalse"
                    }
                },
                {
                    "type": "text",
                    "content": "`\"grape\"` is not in the list, so the first check returns `True`. `\"apple\"` is in the list, so it returns `False`."
                }
            ]
        },
        {
            "id": "not_in_with_if",
            "elements": [
                {
                    "type": "text",
                    "content": "`not in` is useful when you want to do something only if an item is missing."
                },
                {
                    "type": "code",
                    "content": "ingredients = [\"flour\", \"sugar\"]\nif \"eggs\" not in ingredients:\n    print(\"Add eggs to the list!\")",
                    "properties": {
                        "language": "python",
                        "output": "Add eggs to the list!"
                    }
                },
                {
                    "type": "text",
                    "content": "Since `\"eggs\"` is not in the list, the message is printed."
                }
            ]
        },
