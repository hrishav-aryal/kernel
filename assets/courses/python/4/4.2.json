    "blocks": [
        {
            "id": "intro_accessing_lists",
            "elements": [
                {
                    "type": "heading",
                    "content": "Accessing List Items",
                    "properties": {
                        "level": 1
                    }
                },
                {
                    "type": "text",
                    "content": "Once you have a list, you need to be able to get individual items from it. Each item in a list has a position called an **index**."
                },
                {
                    "type": "text",
                    "content": "You can access any item in a list by using its index inside square brackets `[]`."
                }
            ]
        },
        {
            "id": "basic_indexing",
            "elements": [
                {
                    "type": "heading",
                    "content": "Index Basics",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "In Python, list indexing starts at `0`. This means the first item is at index `0`, the second item is at index `1`, and so on."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits[0])",
                    "properties": {
                        "language": "python",
                        "output": "apple"
                    }
                },
                {
                    "type": "text",
                    "content": "`fruits[0]` gives you the first item in the list, which is `\"apple\"`."
                }
            ]
        },
        {
            "id": "accessing_different_positions",
            "elements": [
                {
                    "type": "text",
                    "content": "You can access any position in the list by changing the index number."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits[1])\nprint(fruits[2])",
                    "properties": {
                        "language": "python",
                        "output": "banana\norange"
                    }
                },
                {
                    "type": "text",
                    "content": "`fruits[1]` gives you `\"banana\"` and `fruits[2]` gives you `\"orange\"`."
                }
            ]
        },
