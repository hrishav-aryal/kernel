        {
            "id": "index_errors",
            "elements": [
                {
                    "type": "heading",
                    "content": "Index Out of Range",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "**Be careful!** If you try to access an index that doesn't exist, you'll get an error."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\"]\nprint(fruits[5])",
                    "properties": {
                        "language": "python",
                        "output": "Error: list index out of range"
                    }
                },
                {
                    "type": "text",
                    "content": "This list only has 2 items (at indices 0 and 1), so trying to access index 5 causes an error."
                }
            ]
        },
