        {
            "id": "using_variables_as_index",
            "elements": [
                {
                    "type": "text",
                    "content": "You can also use variables as indices. This is useful when you want to access different positions based on some logic."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nposition = 1\nprint(fruits[position])",
                    "properties": {
                        "language": "python",
                        "output": "banana"
                    }
                },
                {
                    "type": "text",
                    "content": "The variable `position` holds the value `1`, so `fruits[position]` is the same as `fruits[1]`."
                }
            ]
        },
