        {
            "id": "negative_indexing",
            "elements": [
                {
                    "type": "heading",
                    "content": "Negative Indexing",
                    "properties": {
                        "level": 2
                    }
                },
                {
                    "type": "text",
                    "content": "You can also use negative indices to access items from the end of the list. `-1` gives you the last item, `-2` gives you the second-to-last item, and so on."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits[-1])",
                    "properties": {
                        "language": "python",
                        "output": "orange"
                    }
                },
                {
                    "type": "text",
                    "content": "`fruits[-1]` gives you the last item in the list, which is `\"orange\"`."
                }
            ]
        },
        {
            "id": "negative_indexing_more",
            "elements": [
                {
                    "type": "text",
                    "content": "Negative indexing is useful when you want to get items from the end without knowing the exact length of the list."
                },
                {
                    "type": "code",
                    "content": "fruits = [\"apple\", \"banana\", \"orange\"]\nprint(fruits[-2])\nprint(fruits[-3])",
                    "properties": {
                        "language": "python",
                        "output": "banana\napple"
                    }
                },
                {
                    "type": "text",
                    "content": "`fruits[-2]` gives you the second-to-last item and `fruits[-3]` gives you the third-to-last item."
                }
            ]
        },
